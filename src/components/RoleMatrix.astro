---
import { getChapters } from '../lib/chapters';
import { getRoles } from '../lib/roles';

const allChapters = getChapters().filter(c => !c.hidden);
const allRoles = getRoles();

// Build role → chapter slug set
const roleChapterSets = new Map<string, Set<string>>();
for (const role of allRoles) {
  const set = new Set<string>();
  role.phases?.forEach(phase => phase.chapters.forEach((slug: string) => set.add(slug)));
  roleChapterSets.set(role.slug, set);
}

// Derive pillar order directly from the already-sorted getChapters() output,
// which uses order.json internally — so this matches order.json exactly.
const pillarOrder: string[] = [];
for (const ch of allChapters) {
  const p = ch.pillar ?? 'technology';
  if (!pillarOrder.includes(p)) pillarOrder.push(p);
}

const pillarMeta: Record<string, { label: string; bg: string; color: string }> = {
  technology: { label: 'Technology', bg: '#f0fdf4', color: '#15803d' },
  process:    { label: 'Process',    bg: '#eff6ff', color: '#1d4ed8' },
  data:       { label: 'Data',       bg: '#fffbeb', color: '#b45309' },
  people:     { label: 'People',     bg: '#fff1f2', color: '#be123c' },
};

const moduleLabels: Record<string, string> = {
  'planning-software':         'Planning Software',
  'erp':                       'ERP',
  'architecture':              'Architecture & Integration',
  'mdm':                       'MDM Tool',
  'fms':                       'FMS Tool',
  'data-driven-planning':      'Data-Driven Planning',
  'data-fundamentals':         'Data Fundamentals',
  'data-governance':           'Data Governance',
  'reporting':                 'Reporting',
  'process-fundamentals':       'Process Fundamentals',
  'scenario-planning':         'Scenario Planning',
  'sop-process':               'S&OP',
  'soe-process':               'S&OE',
  'execution-process':         'Execution',
  'organisation':              'Organisation',
  'roles-and-responsibilities': 'Roles & Responsibilities',
  'implementation-and-change': 'Implementation & Change',
};

type ModuleGroup = { key: string; label: string; chapters: typeof allChapters };
type PillarGroup = { key: string; label: string; bg: string; color: string; modules: ModuleGroup[] };

const pillars: PillarGroup[] = [];
for (const pillarKey of pillarOrder) {
  const pChapters = allChapters.filter(c => (c.pillar ?? 'technology') === pillarKey);
  if (!pChapters.length) continue;

  const seenMods = new Set<string>();
  const modsOrdered: string[] = [];
  for (const ch of pChapters) {
    const m = ch.module ?? 'planning-software';
    if (!seenMods.has(m)) { seenMods.add(m); modsOrdered.push(m); }
  }

  const meta = pillarMeta[pillarKey] ?? { label: pillarKey, bg: '#f9fafb', color: '#374151' };
  pillars.push({
    key: pillarKey,
    ...meta,
    modules: modsOrdered.map(mod => ({
      key: mod,
      label: moduleLabels[mod] ?? mod,
      chapters: pChapters.filter(c => (c.module ?? 'planning-software') === mod),
    })),
  });
}

const FIRST_COL_W = 220;
const ROLE_COL_W = 100;
const BAND_H = 26; // height of the department band tier above role names
const ROLE_HEADER_H = 180; // height of the rotated role-name tier (tall enough for long titles)

// Department bands — roles are already sorted by `order`, so each department
// forms a contiguous block of columns. Group consecutive roles by department.
type DeptGroup = { label: string; roles: typeof allRoles };
const deptGroups: DeptGroup[] = [];
for (const role of allRoles) {
  const dep = role.department ?? 'Other';
  const last = deptGroups[deptGroups.length - 1];
  if (last && last.label === dep) last.roles.push(role);
  else deptGroups.push({ label: dep, roles: [role] });
}

// Stable colour per department name (re-used if a department recurs).
const deptColorIdx = new Map<string, number>();
function colorIdxFor(dep: string): number {
  if (!deptColorIdx.has(dep)) deptColorIdx.set(dep, deptColorIdx.size % deptPalette.length);
  return deptColorIdx.get(dep)!;
}

// Slug of the last role in each department block — used to draw the stronger
// vertical separator that runs down through the matrix body.
const groupBoundarySlugs = new Set(deptGroups.map(g => g.roles[g.roles.length - 1].slug));

// Light/dark tints per department, assigned by order of first appearance.
const deptPalette = [
  { light: { bg: '#eef2ff', fg: '#4338ca' }, dark: { bg: '#1e1b4b', fg: '#a5b4fc' } }, // indigo
  { light: { bg: '#ecfdf5', fg: '#047857' }, dark: { bg: '#022c22', fg: '#6ee7b7' } }, // emerald
  { light: { bg: '#fffbeb', fg: '#b45309' }, dark: { bg: '#451a03', fg: '#fcd34d' } }, // amber
  { light: { bg: '#fff1f2', fg: '#be123c' }, dark: { bg: '#4c0519', fg: '#fda4af' } }, // rose
  { light: { bg: '#f0f9ff', fg: '#0369a1' }, dark: { bg: '#082f49', fg: '#7dd3fc' } }, // sky
  { light: { bg: '#f5f3ff', fg: '#6d28d9' }, dark: { bg: '#2e1065', fg: '#c4b5fd' } }, // violet
  { light: { bg: '#f0fdfa', fg: '#0f766e' }, dark: { bg: '#042f2e', fg: '#5eead4' } }, // teal
  { light: { bg: '#fff7ed', fg: '#c2410c' }, dark: { bg: '#431407', fg: '#fdba74' } }, // orange
  { light: { bg: '#f7fee7', fg: '#4d7c0f' }, dark: { bg: '#1a2e05', fg: '#bef264' } }, // lime
  { light: { bg: '#fdf4ff', fg: '#a21caf' }, dark: { bg: '#4a044e', fg: '#f0abfc' } }, // fuchsia
];

// Generated CSS so each band index gets the right light + dark tint.
let deptCss = '';
deptPalette.forEach((p, i) => {
  deptCss += `#role-matrix .rm-dept-band[data-dept-idx="${i}"]{background:${p.light.bg};color:${p.light.fg};}`;
  deptCss += `.dark #role-matrix .rm-dept-band[data-dept-idx="${i}"]{background:${p.dark.bg};color:${p.dark.fg};}`;
});
---

<style is:global>
  /* CSS variables scoped to the matrix overlay */
  #role-matrix {
    --rm-bg:           white;
    --rm-surface:      #f9fafb;
    --rm-border:       #e5e7eb;
    --rm-border-strong:#d1d5db;
    --rm-border-light: #f3f4f6;
    --rm-text:         #374151;
    --rm-text-muted:   #6b7280;
    --rm-text-faint:   #9ca3af;
    --rm-dot:          #6366f1;
  }
  .dark #role-matrix {
    --rm-bg:           #222222;
    --rm-surface:      #1e293b;
    --rm-border:       #334155;
    --rm-border-strong:#475569;
    --rm-border-light: #1e293b;
    --rm-text:         #f1f5f9;
    --rm-text-muted:   #94a3b8;
    --rm-text-faint:   #64748b;
    --rm-dot:          #818cf8;
  }

  /* Pillar row backgrounds — light mode */
  #role-matrix .rm-pillar-row[data-pillar="technology"] { background: #f0fdf4; }
  #role-matrix .rm-pillar-row[data-pillar="process"]    { background: #eff6ff; }
  #role-matrix .rm-pillar-row[data-pillar="data"]       { background: #fffbeb; }
  #role-matrix .rm-pillar-row[data-pillar="people"]     { background: #fff1f2; }

  /* Sticky first-column cell in pillar rows — light mode */
  #role-matrix .rm-pillar-row[data-pillar="technology"] .rm-pillar-sticky { background: #f0fdf4; color: #15803d; }
  #role-matrix .rm-pillar-row[data-pillar="process"]    .rm-pillar-sticky { background: #eff6ff; color: #1d4ed8; }
  #role-matrix .rm-pillar-row[data-pillar="data"]       .rm-pillar-sticky { background: #fffbeb; color: #b45309; }
  #role-matrix .rm-pillar-row[data-pillar="people"]     .rm-pillar-sticky { background: #fff1f2; color: #be123c; }

  /* Pillar row backgrounds — dark mode */
  .dark #role-matrix .rm-pillar-row[data-pillar="technology"] { background: #052e16; }
  .dark #role-matrix .rm-pillar-row[data-pillar="process"]    { background: #172554; }
  .dark #role-matrix .rm-pillar-row[data-pillar="data"]       { background: #431407; }
  .dark #role-matrix .rm-pillar-row[data-pillar="people"]     { background: #4c0519; }

  /* Sticky first-column cell in pillar rows — dark mode */
  .dark #role-matrix .rm-pillar-row[data-pillar="technology"] .rm-pillar-sticky { background: #052e16; color: #4ade80; }
  .dark #role-matrix .rm-pillar-row[data-pillar="process"]    .rm-pillar-sticky { background: #172554; color: #60a5fa; }
  .dark #role-matrix .rm-pillar-row[data-pillar="data"]       .rm-pillar-sticky { background: #431407; color: #fbbf24; }
  .dark #role-matrix .rm-pillar-row[data-pillar="people"]     .rm-pillar-sticky { background: #4c0519; color: #fb7185; }

  /* Module roll-up dot — only visible while the module row is collapsed */
  #role-matrix .rm-module-dot { display: none; }
  #role-matrix .rm-module-row[data-collapsed] .rm-module-dot { display: block; }

  /* Depth selector — segmented control in the header */
  #role-matrix .rm-depth-seg { display: inline-flex; align-items: center; border: 1px solid var(--rm-border); border-radius: 6px; overflow: hidden; }
  #role-matrix .rm-depth-btn {
    background: transparent;
    color: var(--rm-text-muted);
    border: none;
    cursor: pointer;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    padding: 4px 9px;
    transition: background 0.12s, color 0.12s;
  }
  #role-matrix .rm-depth-btn + .rm-depth-btn { border-left: 1px solid var(--rm-border); }
  #role-matrix .rm-depth-btn:hover { background: var(--rm-surface); color: var(--rm-text); }
  #role-matrix .rm-depth-btn.rm-depth-active { background: var(--rm-dot); color: #fff; }
</style>

<style is:global set:html={deptCss}></style>

<div
  id="role-matrix"
  class="fixed inset-0 z-[9997] hidden flex-col bg-white dark:bg-neutral-900"
  role="dialog"
  aria-modal="true"
  aria-label="Role chapter matrix"
>
  <!-- Header bar -->
  <div class="flex items-center justify-between px-5 py-3 border-b border-gray-200 dark:border-neutral-700 shrink-0 bg-white dark:bg-neutral-900">
    <div class="flex items-center gap-3">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Role &times; Chapter Matrix</h2>
      <span class="text-xs text-gray-400 dark:text-neutral-500 hidden sm:inline">
        {allRoles.filter(r => !r.comingSoon).length} active &nbsp;·&nbsp; {allRoles.filter(r => r.comingSoon).length} coming soon
      </span>
      <div class="rm-depth-seg" role="group" aria-label="Collapse depth">
        <button type="button" class="rm-depth-btn" data-depth="modules">Modules</button>
        <button type="button" class="rm-depth-btn rm-depth-active" data-depth="chapters">Chapters</button>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs text-gray-400 dark:text-neutral-500 hidden sm:inline">
        <kbd class="font-mono bg-gray-100 dark:bg-neutral-800 px-1 py-0.5 rounded text-gray-500 dark:text-neutral-400">M</kbd> toggle
        &nbsp;·&nbsp;
        <kbd class="font-mono bg-gray-100 dark:bg-neutral-800 px-1 py-0.5 rounded text-gray-500 dark:text-neutral-400">Esc</kbd> close
      </span>
      <button
        id="role-matrix-close"
        class="text-gray-400 hover:text-gray-700 dark:hover:text-neutral-300 transition-colors p-1 rounded"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Scrollable table area -->
  <div class="flex-1 overflow-auto" id="role-matrix-scroll">
    <table style={`border-collapse: separate; border-spacing: 0; min-width: ${FIRST_COL_W + allRoles.length * ROLE_COL_W}px;`}>

      <!-- Role header rows: department band on top, rotated role names below -->
      <thead>
        <tr>
          <!-- Corner (spans both header tiers) -->
          <th rowspan={2} style={`position: sticky; left: 0; top: 0; z-index: 40; background: var(--rm-bg); width: ${FIRST_COL_W}px; min-width: ${FIRST_COL_W}px; height: ${ROLE_HEADER_H + BAND_H}px; padding: 0; vertical-align: bottom; border-right: 1px solid var(--rm-border); border-bottom: 2px solid var(--rm-border);`}>
            <div style="padding: 6px 10px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--rm-text-faint);">
              Chapter
            </div>
          </th>
          <!-- Department band -->
          {deptGroups.map(g => (
            <th
              class="rm-dept-band"
              data-dept-idx={colorIdxFor(g.label)}
              colspan={g.roles.length}
              title={g.label}
              style={`position: sticky; top: 0; z-index: 30; height: ${BAND_H}px; padding: 0 8px; text-align: center; vertical-align: middle; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; border-right: 2px solid var(--rm-border-strong); border-bottom: 1px solid var(--rm-border);`}
            >
              {g.label}
            </th>
          ))}
        </tr>
        <tr>
          <!-- Role columns -->
          {allRoles.map(role => (
            <th
              title={role.title}
              style={`position: sticky; top: ${BAND_H}px; z-index: 20; background: var(--rm-bg); width: ${ROLE_COL_W}px; min-width: ${ROLE_COL_W}px; height: ${ROLE_HEADER_H}px; padding: 0; vertical-align: bottom; border-right: ${groupBoundarySlugs.has(role.slug) ? '2px solid var(--rm-border-strong)' : '1px solid var(--rm-border-light)'}; border-bottom: 2px solid var(--rm-border); opacity: ${role.comingSoon ? 0.45 : 1};`}
            >
              <div style={`position: relative; height: ${ROLE_HEADER_H}px; width: ${ROLE_COL_W}px; overflow: visible;`}>
                <span style={`position: absolute; bottom: 8px; left: ${ROLE_COL_W / 2}px; white-space: nowrap; font-size: 11px; font-weight: 500; color: var(--rm-text); display: block; transform-origin: left bottom; transform: rotate(-70deg);`}>
                  {role.title}
                </span>
              </div>
            </th>
          ))}
        </tr>
      </thead>

      <!-- Body rows -->
      <tbody>
        {pillars.map(pillar => (
          <>
            {/* Pillar header row */}
            <tr class="rm-pillar-row" data-pillar={pillar.key} style="cursor: pointer;">
              <td
                class="rm-pillar-sticky"
                style={`position: sticky; left: 0; z-index: 10; width: ${FIRST_COL_W}px; min-width: ${FIRST_COL_W}px; padding: 5px 10px; border-right: 1px solid var(--rm-border-strong); border-bottom: 1px solid var(--rm-border-strong); font-weight: 700; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap; user-select: none;`}
              >
                <span class="rm-chevron" style="display: inline-block; font-size: 8px; margin-right: 5px; transition: transform 0.15s; transform: rotate(90deg);">▶</span>
                {pillar.label}
              </td>
              {allRoles.map(role => (
                <td style={`border-right: ${groupBoundarySlugs.has(role.slug) ? '2px solid var(--rm-border-strong)' : '1px solid var(--rm-border)'}; border-bottom: 1px solid var(--rm-border-strong);`}></td>
              ))}
            </tr>

            {/* Module and chapter rows */}
            {pillar.modules.map(mod => (
              <>
                <tr class="rm-module-row" data-pillar={pillar.key} data-module={mod.key} style="background: var(--rm-surface); cursor: pointer;">
                  <td
                    style={`position: sticky; left: 0; z-index: 10; background: var(--rm-surface); width: ${FIRST_COL_W}px; min-width: ${FIRST_COL_W}px; padding: 4px 10px 4px 24px; border-right: 1px solid var(--rm-border-strong); border-bottom: 1px solid var(--rm-border); font-weight: 600; font-size: 11px; color: var(--rm-text-muted); white-space: nowrap; user-select: none;`}
                  >
                    <span class="rm-chevron" style="display: inline-block; font-size: 8px; margin-right: 5px; transition: transform 0.15s; transform: rotate(90deg);">▶</span>
                    {mod.label}
                  </td>
                  {allRoles.map(role => {
                    const moduleAssigned = mod.chapters.some(ch => roleChapterSets.get(role.slug)?.has(ch.slug));
                    return (
                      <td style={`background: var(--rm-surface); border-right: ${groupBoundarySlugs.has(role.slug) ? '2px solid var(--rm-border-strong)' : '1px solid var(--rm-border-light)'}; border-bottom: 1px solid var(--rm-border); text-align: center; padding: 3px 0; opacity: ${role.comingSoon ? 0.45 : 1};`}>
                        {moduleAssigned && (
                          <div class="rm-module-dot" style="width: 8px; height: 8px; border-radius: 50%; background: var(--rm-dot); margin: 0 auto;"></div>
                        )}
                      </td>
                    );
                  })}
                </tr>

                {mod.chapters.map(ch => {
                  return (
                    <tr class="rm-chapter-row" data-pillar={pillar.key} data-module={mod.key}>
                      <td
                        title={ch.title}
                        style={`position: sticky; left: 0; z-index: 10; background: var(--rm-bg); width: ${FIRST_COL_W}px; min-width: ${FIRST_COL_W}px; max-width: ${FIRST_COL_W}px; padding: 3px 10px 3px 36px; border-right: 1px solid var(--rm-border); border-bottom: 1px solid var(--rm-border-light); font-size: 12px; color: var(--rm-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;`}
                      >
                        {ch.title}
                      </td>
                      {allRoles.map(role => {
                        const assigned = roleChapterSets.get(role.slug)?.has(ch.slug) ?? false;
                        return (
                          <td style={`border-right: ${groupBoundarySlugs.has(role.slug) ? '2px solid var(--rm-border-strong)' : '1px solid var(--rm-border-light)'}; border-bottom: 1px solid var(--rm-border-light); text-align: center; padding: 3px 0; opacity: ${role.comingSoon ? 0.45 : 1};`}>
                            {assigned && (
                              <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--rm-dot); margin: 0 auto;"></div>
                            )}
                          </td>
                        );
                      })}
                    </tr>
                  );
                })}
              </>
            ))}
          </>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Footer -->
  <div class="border-t border-gray-200 dark:border-neutral-700 px-5 py-2 shrink-0 flex items-center gap-5 bg-white dark:bg-neutral-900">
    <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-neutral-500">
      <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--rm-dot); display: inline-block;"></div>
      Chapter assigned to role
    </div>
    <span class="text-xs text-gray-300 dark:text-neutral-600">|</span>
    <span class="text-xs text-gray-400 dark:text-neutral-500">Coloured top bands group roles by department</span>
    <span class="text-xs text-gray-300 dark:text-neutral-600">|</span>
    <span class="text-xs text-gray-400 dark:text-neutral-500">Dimmed columns = coming soon roles</span>
    <span class="text-xs text-gray-300 dark:text-neutral-600">|</span>
    <span class="text-xs text-gray-400 dark:text-neutral-500">Click pillar or module labels to collapse</span>
  </div>
</div>

<script>
  const overlay  = document.getElementById('role-matrix')!;
  const closeBtn = document.getElementById('role-matrix-close')!;
  const depthBtns = overlay.querySelectorAll<HTMLElement>('.rm-depth-btn');

  // Sync a row's collapsed attribute + chevron to a target state
  function setRowCollapsed(row: HTMLElement, collapsed: boolean) {
    const chevron = row.querySelector<HTMLElement>('.rm-chevron');
    if (collapsed) {
      row.setAttribute('data-collapsed', '');
      if (chevron) chevron.style.transform = '';
    } else {
      row.removeAttribute('data-collapsed');
      if (chevron) chevron.style.transform = 'rotate(90deg)';
    }
  }

  // Re-level the entire matrix to a single depth
  function setDepth(level: string) {
    const pillarRows  = overlay.querySelectorAll<HTMLElement>('.rm-pillar-row');
    const moduleRows  = overlay.querySelectorAll<HTMLElement>('.rm-module-row');
    const chapterRows = overlay.querySelectorAll<HTMLElement>('.rm-chapter-row');

    if (level === 'modules') {
      pillarRows.forEach(r => setRowCollapsed(r, false));
      moduleRows.forEach(r => { setRowCollapsed(r, true); r.style.display = ''; });
      chapterRows.forEach(r => { r.style.display = 'none'; });
    } else {
      pillarRows.forEach(r => setRowCollapsed(r, false));
      moduleRows.forEach(r => { setRowCollapsed(r, false); r.style.display = ''; });
      chapterRows.forEach(r => { r.style.display = ''; });
    }

    depthBtns.forEach(b => b.classList.toggle('rm-depth-active', b.dataset.depth === level));
  }

  // De-highlight the selector once the matrix is no longer at a uniform depth
  function clearDepth() {
    depthBtns.forEach(b => b.classList.remove('rm-depth-active'));
  }

  depthBtns.forEach(btn => {
    btn.addEventListener('click', () => setDepth(btn.dataset.depth ?? 'chapters'));
  });

  function open() {
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function toggle() {
    overlay.classList.contains('hidden') ? open() : close();
  }

  // Pillar row toggle
  overlay.querySelectorAll<HTMLElement>('.rm-pillar-row').forEach(row => {
    row.addEventListener('click', () => {
      clearDepth();
      const pillar = row.dataset.pillar!;
      const isCollapsed = row.hasAttribute('data-collapsed');
      const chevron = row.querySelector<HTMLElement>('.rm-chevron');

      if (isCollapsed) {
        row.removeAttribute('data-collapsed');
        // Show module rows; chapter rows only if their module isn't also collapsed
        overlay.querySelectorAll<HTMLElement>('.rm-module-row').forEach(r => {
          if (r.dataset.pillar === pillar) r.style.display = '';
        });
        overlay.querySelectorAll<HTMLElement>('.rm-chapter-row').forEach(r => {
          if (r.dataset.pillar === pillar) {
            const modRow = overlay.querySelector<HTMLElement>(
              `.rm-module-row[data-pillar="${pillar}"][data-module="${r.dataset.module}"]`
            );
            if (!modRow?.hasAttribute('data-collapsed')) r.style.display = '';
          }
        });
        if (chevron) chevron.style.transform = 'rotate(90deg)';
      } else {
        row.setAttribute('data-collapsed', '');
        overlay.querySelectorAll<HTMLElement>('.rm-module-row, .rm-chapter-row').forEach(r => {
          if (r.dataset.pillar === pillar) r.style.display = 'none';
        });
        if (chevron) chevron.style.transform = '';
      }
    });
  });

  // Module row toggle (stop bubbling to pillar row)
  overlay.querySelectorAll<HTMLElement>('.rm-module-row').forEach(row => {
    row.addEventListener('click', e => {
      e.stopPropagation();
      clearDepth();
      const pillar = row.dataset.pillar!;
      const mod = row.dataset.module!;
      const isCollapsed = row.hasAttribute('data-collapsed');
      const chevron = row.querySelector<HTMLElement>('.rm-chevron');

      if (isCollapsed) {
        row.removeAttribute('data-collapsed');
        overlay.querySelectorAll<HTMLElement>('.rm-chapter-row').forEach(r => {
          if (r.dataset.pillar === pillar && r.dataset.module === mod) r.style.display = '';
        });
        if (chevron) chevron.style.transform = 'rotate(90deg)';
      } else {
        row.setAttribute('data-collapsed', '');
        overlay.querySelectorAll<HTMLElement>('.rm-chapter-row').forEach(r => {
          if (r.dataset.pillar === pillar && r.dataset.module === mod) r.style.display = 'none';
        });
        if (chevron) chevron.style.transform = '';
      }
    });
  });

  // Keyboard handler
  document.addEventListener('keydown', e => {
    const tag = (e.target as HTMLElement).tagName;
    const inInput = tag === 'INPUT' || tag === 'TEXTAREA' || (e.target as HTMLElement).isContentEditable;
    if (e.key === 'Escape') { close(); return; }
    if ((e.key === 'm' || e.key === 'M') && !inInput && !e.metaKey && !e.ctrlKey) {
      e.preventDefault();
      toggle();
    }
  });

  closeBtn.addEventListener('click', close);
</script>
