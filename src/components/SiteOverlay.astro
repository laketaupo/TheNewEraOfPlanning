---
import { getChapters, getTopics, getChapterUrl } from '../lib/chapters';

const allChapters = getChapters().filter(c => !c.hidden);
const allTopics = getTopics();

const pillarOrder = ['technology', 'process', 'data', 'people'];

const pillarMeta: Record<string, { label: string; accent: string; line: string }> = {
  technology: { label: 'Technology', accent: 'text-sky-600 dark:text-sky-400',     line: 'bg-sky-100 dark:bg-sky-500/20' },
  process:    { label: 'Process',    accent: 'text-violet-600 dark:text-violet-400', line: 'bg-violet-100 dark:bg-violet-500/20' },
  data:       { label: 'Data',       accent: 'text-emerald-600 dark:text-emerald-400', line: 'bg-emerald-100 dark:bg-emerald-500/20' },
  people:     { label: 'People',     accent: 'text-amber-600 dark:text-amber-400',  line: 'bg-amber-100 dark:bg-amber-500/20' },
};

const moduleLabels: Record<string, string> = {
  'how-o9-works':         'How o9 Works',
  'business-central':     'Business Central',
  'architecture':         'Architecture & Integration',
  'ecosystem':            'System Ecosystem',
  'data-driven-planning': 'Data-Driven Planning',
  'scenario-planning':    'Scenario Planning',
  'people-and-planning':  'People & Planning',
};

const pillars = pillarOrder.map(pillar => {
  const pChapters = allChapters.filter(c => c.pillar === pillar);
  const modules = [...new Set(pChapters.map(c => c.module ?? ''))].filter(Boolean);
  return {
    pillar,
    ...pillarMeta[pillar],
    multiModule: modules.length > 1,
    modules: modules.map(mod => ({
      key: mod,
      label: moduleLabels[mod] ?? mod,
      chapters: pChapters
        .filter(c => c.module === mod)
        .map(ch => ({
          slug: ch.slug,
          title: ch.title,
          url: getChapterUrl(ch),
          topics: allTopics.filter(t => t.chapterSlug === ch.slug),
        })),
    })),
  };
}).filter(p => p.modules.length > 0);

const totalTopics = allTopics.length;
---

<!-- Site overlay — toggled by pressing 'o' -->
<div
  id="site-overlay"
  class="fixed inset-0 z-[9999] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Site overview"
>
  <!-- Backdrop -->
  <div id="site-overlay-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative z-10 flex flex-col h-full max-w-2xl mx-auto px-4 py-6 pointer-events-none">
    <div class="flex flex-col bg-white dark:bg-gray-900 rounded-2xl shadow-2xl overflow-hidden pointer-events-auto max-h-full">

      <!-- Search bar -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-100 dark:border-gray-800 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 111 11a6 6 0 0116 0z"/>
        </svg>
        <input
          id="site-overlay-search"
          type="text"
          placeholder="Filter pagina's…"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 bg-transparent text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 outline-none"
        />
        <span class="text-xs text-gray-400 dark:text-gray-500 shrink-0 tabular-nums">{totalTopics} topics</span>
        <button
          id="site-overlay-close"
          class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors shrink-0 ml-1"
          aria-label="Sluiten"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Tree content -->
      <div id="site-overlay-content" class="overflow-y-auto flex-1 py-3">

        {pillars.map((pillar, pi) => (
          <section class="pillar-section" data-pillar={pillar.pillar}>

            {/* ── Pillar row ── */}
            <div class={`flex items-center gap-2 px-5 py-2 ${pi > 0 ? 'mt-2' : ''}`}>
              <span class={`text-[10px] font-bold uppercase tracking-widest ${pillar.accent}`}>{pillar.label}</span>
              <div class={`flex-1 h-px ${pillar.line}`}></div>
            </div>

            {pillar.modules.map(mod => (
              <div class="module-group" data-module={mod.key}>

                {/* ── Module row (only when >1 module per pillar) ── */}
                {pillar.multiModule && (
                  <div class="flex items-center gap-2 pl-8 pr-5 py-1.5">
                    <span class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{mod.label}</span>
                    <div class="flex-1 h-px bg-gray-100 dark:bg-gray-800"></div>
                  </div>
                )}

                {mod.chapters.map(ch => (
                  <div class="chapter-card" data-chapter={ch.title.toLowerCase()}>

                    {/* ── Chapter row ── */}
                    <a
                      href={ch.url}
                      class="chapter-link flex items-center gap-2 pl-12 pr-5 py-1 group"
                      data-search={ch.title.toLowerCase()}
                    >
                      <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600 shrink-0 group-hover:bg-gray-500 dark:group-hover:bg-gray-400 transition-colors"></span>
                      <span class="text-sm font-semibold text-gray-700 dark:text-gray-200 group-hover:text-gray-900 dark:group-hover:text-white transition-colors leading-snug">
                        {ch.title}
                      </span>
                    </a>

                    {/* ── Topic rows ── */}
                    <ul>
                      {ch.topics.map(t => (
                        <li class="topic-item" data-search={`${ch.title} ${t.title}`.toLowerCase()}>
                          <a
                            href={t.url}
                            class="flex items-center gap-2 pl-16 pr-5 py-0.5 group"
                          >
                            <span class="w-0.5 h-0.5 rounded-full bg-gray-200 dark:bg-gray-700 shrink-0"></span>
                            <span class="text-xs text-gray-500 dark:text-gray-400 group-hover:text-gray-800 dark:group-hover:text-gray-100 transition-colors leading-snug truncate">
                              {t.title}
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>

                  </div>
                ))}
              </div>
            ))}

          </section>
        ))}

        <!-- Empty state -->
        <p id="site-overlay-empty" class="hidden text-sm text-gray-400 dark:text-gray-500 text-center py-10">Geen pagina's gevonden.</p>

      </div>

      <!-- Footer hint -->
      <div class="px-5 py-2.5 border-t border-gray-100 dark:border-gray-800 shrink-0">
        <span class="text-xs text-gray-400 dark:text-gray-600">
          <kbd class="font-mono bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-gray-500 dark:text-gray-400">O</kbd> openen/sluiten
          &nbsp;·&nbsp;
          <kbd class="font-mono bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-gray-500 dark:text-gray-400">Esc</kbd> sluiten
        </span>
      </div>

    </div>
  </div>
</div>

<script>
  const overlay  = document.getElementById('site-overlay')!;
  const backdrop = document.getElementById('site-overlay-backdrop')!;
  const closeBtn = document.getElementById('site-overlay-close')!;
  const search   = document.getElementById('site-overlay-search') as HTMLInputElement;
  const empty    = document.getElementById('site-overlay-empty')!;

  function open() {
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    search.value = '';
    applyFilter('');
    setTimeout(() => search.focus(), 50);
  }

  function close() {
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function toggle() {
    overlay.classList.contains('hidden') ? open() : close();
  }

  function applyFilter(q: string) {
    const term = q.toLowerCase().trim();
    let anyVisible = false;

    document.querySelectorAll<HTMLElement>('.chapter-card').forEach(card => {
      const chapterText = card.dataset.chapter ?? '';
      const topicItems  = card.querySelectorAll<HTMLElement>('.topic-item');

      if (!term) {
        card.style.display = '';
        topicItems.forEach(t => { t.style.display = ''; });
        anyVisible = true;
        return;
      }

      if (chapterText.includes(term)) {
        card.style.display = '';
        topicItems.forEach(t => { t.style.display = ''; });
        anyVisible = true;
      } else {
        let chapterMatch = false;
        topicItems.forEach(t => {
          const match = (t.dataset.search ?? '').includes(term);
          t.style.display = match ? '' : 'none';
          if (match) chapterMatch = true;
        });
        card.style.display = chapterMatch ? '' : 'none';
        if (chapterMatch) anyVisible = true;
      }
    });

    // Hide module groups and pillar sections with no visible content
    document.querySelectorAll<HTMLElement>('.module-group').forEach(mod => {
      const visible = Array.from(mod.querySelectorAll<HTMLElement>('.chapter-card'))
        .some(c => c.style.display !== 'none');
      mod.style.display = visible ? '' : 'none';
    });

    document.querySelectorAll<HTMLElement>('.pillar-section').forEach(sec => {
      const visible = Array.from(sec.querySelectorAll<HTMLElement>('.module-group'))
        .some(m => m.style.display !== 'none');
      sec.style.display = visible ? '' : 'none';
    });

    empty.classList.toggle('hidden', anyVisible);
  }

  // Keyboard
  document.addEventListener('keydown', (e) => {
    const tag = (e.target as HTMLElement).tagName;
    const inInput = tag === 'INPUT' || tag === 'TEXTAREA' || (e.target as HTMLElement).isContentEditable;
    if (e.key === 'Escape') { close(); return; }
    if ((e.key === 'o' || e.key === 'O') && !inInput && !e.metaKey && !e.ctrlKey) {
      e.preventDefault();
      toggle();
    }
  });

  backdrop.addEventListener('click', close);
  closeBtn.addEventListener('click', close);
  overlay.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
  search.addEventListener('input', () => applyFilter(search.value));
</script>
