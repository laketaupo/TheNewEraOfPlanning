---
import { getChapters, getTopics, getChapterUrl } from '../lib/chapters';

const allChapters = getChapters().filter(c => !c.hidden);
const allTopics = getTopics();

const pillarOrder = ['technology', 'process', 'data', 'people'];

const pillarMeta: Record<string, { label: string; accent: string; badge: string }> = {
  technology: { label: 'Technology', accent: 'text-sky-600 dark:text-sky-400',   badge: 'bg-sky-50 dark:bg-sky-500/10 border-sky-200 dark:border-sky-500/30 text-sky-700 dark:text-sky-300' },
  process:    { label: 'Process',    accent: 'text-violet-600 dark:text-violet-400', badge: 'bg-violet-50 dark:bg-violet-500/10 border-violet-200 dark:border-violet-500/30 text-violet-700 dark:text-violet-300' },
  data:       { label: 'Data',       accent: 'text-emerald-600 dark:text-emerald-400', badge: 'bg-emerald-50 dark:bg-emerald-500/10 border-emerald-200 dark:border-emerald-500/30 text-emerald-700 dark:text-emerald-300' },
  people:     { label: 'People',     accent: 'text-amber-600 dark:text-amber-400',  badge: 'bg-amber-50 dark:bg-amber-500/10 border-amber-200 dark:border-amber-500/30 text-amber-700 dark:text-amber-300' },
};

const moduleLabels: Record<string, string> = {
  'how-o9-works':         'How o9 Works',
  'business-central':     'Business Central',
  'architecture':         'Architecture & Integration',
  'ecosystem':            'System Ecosystem',
  'data-driven-planning': 'Data-Driven Planning',
  'scenario-planning':    'Scenario Planning',
  'people-and-planning':  'People & Planning',
};

const pillars = pillarOrder.map(pillar => {
  const pChapters = allChapters.filter(c => c.pillar === pillar);
  const modules = [...new Set(pChapters.map(c => c.module ?? ''))].filter(Boolean);
  return {
    pillar,
    ...pillarMeta[pillar],
    modules: modules.map(mod => ({
      label: moduleLabels[mod] ?? mod,
      chapters: pChapters
        .filter(c => c.module === mod)
        .map(ch => ({
          slug: ch.slug,
          title: ch.title,
          url: getChapterUrl(ch),
          color: ch.color,
          topics: allTopics.filter(t => t.chapterSlug === ch.slug),
        })),
    })),
  };
}).filter(p => p.modules.length > 0);

const totalTopics = allTopics.length;
---

<!-- Site overlay — toggled by pressing 'o' -->
<div
  id="site-overlay"
  class="fixed inset-0 z-[9999] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Site overview"
>
  <!-- Backdrop -->
  <div id="site-overlay-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative z-10 flex flex-col h-full max-w-6xl mx-auto px-4 py-6 pointer-events-none">
    <div class="flex flex-col bg-white dark:bg-gray-900 rounded-2xl shadow-2xl overflow-hidden pointer-events-auto max-h-full">

      <!-- Header -->
      <div class="flex items-center gap-3 px-5 py-4 border-b border-gray-100 dark:border-gray-800 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 111 11a6 6 0 0116 0z"/>
        </svg>
        <input
          id="site-overlay-search"
          type="text"
          placeholder="Filter pages…"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 bg-transparent text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 outline-none"
        />
        <span class="text-xs text-gray-400 dark:text-gray-500 shrink-0">{totalTopics} topics</span>
        <button
          id="site-overlay-close"
          class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors shrink-0 ml-1"
          aria-label="Close"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Content -->
      <div id="site-overlay-content" class="overflow-y-auto p-5 space-y-8 flex-1">
        {pillars.map(pillar => (
          <section class="pillar-section" data-pillar={pillar.pillar}>
            <!-- Pillar heading -->
            <div class="flex items-center gap-3 mb-4">
              <h2 class={`text-xs font-bold uppercase tracking-widest ${pillar.accent}`}>{pillar.label}</h2>
              <div class="flex-1 h-px bg-gray-100 dark:bg-gray-800"></div>
            </div>

            {pillar.modules.map(mod => (
              <div class="module-group mb-5" data-module={mod.label}>
                {/* Module label — only shown when pillar has >1 module */}
                {pillar.modules.length > 1 && (
                  <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2 pl-0.5">{mod.label}</p>
                )}
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                  {mod.chapters.map(ch => (
                    <div class="chapter-card" data-chapter={ch.title.toLowerCase()}>
                      <a
                        href={ch.url}
                        class="chapter-link block text-xs font-semibold text-gray-700 dark:text-gray-200 hover:text-gray-900 dark:hover:text-white mb-1.5 leading-snug"
                        data-search={ch.title.toLowerCase()}
                      >
                        {ch.title}
                      </a>
                      <ul class="space-y-0.5">
                        {ch.topics.map(t => (
                          <li class="topic-item" data-search={`${ch.title} ${t.title}`.toLowerCase()}>
                            <a
                              href={t.url}
                              class="text-xs text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors leading-snug block truncate"
                            >
                              {t.title}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </section>
        ))}

        <!-- Empty state -->
        <p id="site-overlay-empty" class="hidden text-sm text-gray-400 dark:text-gray-500 text-center py-8">No pages match your search.</p>
      </div>

      <!-- Footer hint -->
      <div class="px-5 py-2.5 border-t border-gray-100 dark:border-gray-800 flex items-center gap-4 shrink-0">
        <span class="text-xs text-gray-400 dark:text-gray-600">Press <kbd class="font-mono bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-gray-500 dark:text-gray-400">O</kbd> to toggle &nbsp;·&nbsp; <kbd class="font-mono bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-gray-500 dark:text-gray-400">Esc</kbd> to close</span>
      </div>

    </div>
  </div>
</div>

<script>
  const overlay   = document.getElementById('site-overlay')!;
  const backdrop  = document.getElementById('site-overlay-backdrop')!;
  const closeBtn  = document.getElementById('site-overlay-close')!;
  const search    = document.getElementById('site-overlay-search') as HTMLInputElement;
  const content   = document.getElementById('site-overlay-content')!;
  const empty     = document.getElementById('site-overlay-empty')!;

  function open() {
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    search.value = '';
    applyFilter('');
    setTimeout(() => search.focus(), 50);
  }

  function close() {
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function toggle() {
    overlay.classList.contains('hidden') ? open() : close();
  }

  function applyFilter(q: string) {
    const term = q.toLowerCase().trim();
    let visibleChapters = 0;

    document.querySelectorAll<HTMLElement>('.chapter-card').forEach(card => {
      const chapterText = card.dataset.chapter ?? '';
      const topicItems  = card.querySelectorAll<HTMLElement>('.topic-item');
      let chapterVisible = false;

      if (!term) {
        // Show everything
        card.style.display = '';
        topicItems.forEach(t => t.style.display = '');
        chapterVisible = true;
      } else {
        // Chapter title matches → show chapter and all topics
        if (chapterText.includes(term)) {
          card.style.display = '';
          topicItems.forEach(t => t.style.display = '');
          chapterVisible = true;
        } else {
          // Check individual topics
          let anyTopic = false;
          topicItems.forEach(t => {
            const match = (t.dataset.search ?? '').includes(term);
            t.style.display = match ? '' : 'none';
            if (match) anyTopic = true;
          });
          card.style.display = anyTopic ? '' : 'none';
          chapterVisible = anyTopic;
        }
      }

      if (chapterVisible) visibleChapters++;
    });

    // Hide module groups with no visible chapters
    document.querySelectorAll<HTMLElement>('.module-group').forEach(mod => {
      const anyVisible = Array.from(mod.querySelectorAll<HTMLElement>('.chapter-card'))
        .some(c => c.style.display !== 'none');
      mod.style.display = anyVisible ? '' : 'none';
    });

    // Hide pillar sections with no visible chapters
    document.querySelectorAll<HTMLElement>('.pillar-section').forEach(sec => {
      const anyVisible = Array.from(sec.querySelectorAll<HTMLElement>('.module-group'))
        .some(m => m.style.display !== 'none');
      sec.style.display = anyVisible ? '' : 'none';
    });

    empty.classList.toggle('hidden', visibleChapters > 0);
  }

  // Keyboard: 'o' to toggle, Escape to close
  document.addEventListener('keydown', (e) => {
    const tag = (e.target as HTMLElement).tagName;
    const inInput = tag === 'INPUT' || tag === 'TEXTAREA' || (e.target as HTMLElement).isContentEditable;

    if (e.key === 'Escape') { close(); return; }
    if ((e.key === 'o' || e.key === 'O') && !inInput && !e.metaKey && !e.ctrlKey) {
      e.preventDefault();
      toggle();
    }
  });

  // Close on backdrop click
  backdrop.addEventListener('click', close);
  closeBtn.addEventListener('click', close);

  // Close on topic/chapter link click
  overlay.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', close);
  });

  // Search filter
  search.addEventListener('input', () => applyFilter(search.value));
</script>
