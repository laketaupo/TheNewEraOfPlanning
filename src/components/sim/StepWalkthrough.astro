---
// Step-by-step planning cycle walkthrough
---
<div id="step-walkthrough" class="rounded-2xl border border-sky-200 dark:border-sky-500/20 bg-sky-50/50 dark:bg-gray-900/60 p-6">
  <h3 class="text-sm font-semibold text-sky-400 mb-6 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
    Planning Cycle Walkthrough
  </h3>

  <!-- Progress dots at top -->
  <div class="flex items-center gap-1.5 mb-6">
    {Array.from({ length: 8 }).map((_, i) => (
      <div class="sw-dot h-1.5 rounded-full transition-all duration-300 bg-gray-700" data-step={i} style="width: 8px"></div>
    ))}
    <span id="sw-counter" class="ml-2 text-xs text-gray-500">1 / 8</span>
  </div>

  <!-- Step content area -->
  <div class="min-h-[180px] mb-6">
    <div class="flex items-start gap-4">
      <div id="sw-step-num" class="shrink-0 w-10 h-10 rounded-full bg-sky-100 dark:bg-sky-500/20 border border-sky-300 dark:border-sky-500/40 flex items-center justify-center text-sky-600 dark:text-sky-400 font-bold text-sm">
        1
      </div>
      <div class="flex-1">
        <h4 id="sw-step-title" class="text-lg font-semibold text-white mb-2"></h4>
        <p id="sw-step-desc" class="text-gray-400 text-sm leading-relaxed mb-4"></p>
        <div id="sw-step-panel" class="rounded-xl bg-white dark:bg-gray-800/60 border border-gray-200 dark:border-gray-700 p-4 text-sm"></div>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <div class="flex items-center justify-between">
    <button id="sw-prev" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors disabled:opacity-30 disabled:pointer-events-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Previous
    </button>
    <button id="sw-next" class="flex items-center gap-2 text-sm font-medium text-sky-400 hover:text-sky-300 transition-colors">
      Next
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
  </div>
</div>

<script>
  interface Step {
    title: string;
    desc: string;
    panel: string;
  }

  const STEPS: Step[] = [
    {
      title: 'Open the Workbench',
      desc: 'Start by navigating to your planning workbench in Planning software. The workbench is your personalised view of the supply chain, configured for your role and area of responsibility.',
      panel: `<p class="text-gray-400">📋 <strong class="text-white">Tip:</strong> Your workbench loads with the last saved view. Check the date stamp at the top right to confirm you're looking at the latest data refresh.</p>`,
    },
    {
      title: 'Review Exceptions',
      desc: 'Planning software surfaces only the exceptions that need your attention. Start here before looking at anything else — the exception list tells you what changed since the last planning cycle.',
      panel: `<div class="space-y-2">
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-red-400 shrink-0"></span><span class="text-gray-300 text-xs">3 items at risk of stockout in the next 2 weeks</span></div>
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span><span class="text-gray-300 text-xs">Supplier PO #4421 confirmed 5 days late</span></div>
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span><span class="text-gray-300 text-xs">Filling Line 2 overloaded in week 12 (108%)</span></div>
        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-gray-500 shrink-0"></span><span class="text-gray-400 text-xs">14 items within tolerance — no action needed</span></div>
      </div>`,
    },
    {
      title: 'Assess Demand',
      desc: 'Review the demand forecast for the planning horizon. Validate statistical forecasts against commercial intelligence — promotions, NPIs, market trends — and adjust where needed.',
      panel: `<p class="text-gray-400 text-xs">📊 <strong class="text-white">Key question:</strong> Does the forecast reflect what Sales and Marketing know about the next 3 months? If not, override it with a consensus number before running the supply plan.</p>`,
    },
    {
      title: 'Run the Supply Plan',
      desc: 'Trigger the planning engine. Choose constrained (respects capacity limits) or unconstrained (ignores limits — useful for seeing the full demand picture before resolving constraints).',
      panel: `<div class="space-y-1 text-xs">
        <p class="text-white font-medium mb-2">Planning run options:</p>
        <div class="flex gap-3">
          <div class="flex-1 p-2 rounded-lg bg-gray-700/60 border border-gray-600"><p class="text-emerald-400 font-medium mb-1">Constrained</p><p class="text-gray-400">Respects capacity. Generates executable plan. Use for S&OE.</p></div>
          <div class="flex-1 p-2 rounded-lg bg-gray-700/60 border border-gray-600"><p class="text-sky-400 font-medium mb-1">Unconstrained</p><p class="text-gray-400">Ignores limits. Shows full demand picture. Use for S&OP demand review.</p></div>
        </div>
      </div>`,
    },
    {
      title: 'Review Capacity',
      desc: 'After the plan runs, examine the capacity view. Look for overloaded resources (>100%) in the near term and underloaded resources (wasted capacity) in the mid-term.',
      panel: `<div class="space-y-1.5 text-xs">
        <p class="text-white font-medium mb-2">Resource load — Week 12:</p>
        ${[['Filling Line 1', 78, 'emerald'], ['Filling Line 2', 108, 'red'], ['Mixing Tank A', 65, 'emerald'], ['Labelling', 91, 'amber']].map(
          ([name, pct, color]) => `<div class="flex items-center gap-2">
            <span class="w-24 text-gray-400 shrink-0">${name}</span>
            <div class="flex-1 h-2 bg-gray-700 rounded-full overflow-hidden">
              <div class="h-full bg-${color}-500 rounded-full" style="width:${Math.min(100, Number(pct))}%"></div>
            </div>
            <span class="text-${color}-400 w-8 text-right">${pct}%</span>
          </div>`
        ).join('')}
      </div>`,
    },
    {
      title: 'Resolve Conflicts',
      desc: 'For each capacity overload or service risk, Planning software proposes a resolution. Review the AI-suggested action, accept it or override it with your own judgement.',
      panel: `<div class="text-xs space-y-2">
        <p class="text-white font-medium mb-2">Suggested resolution for Filling Line 2 overload:</p>
        <div class="p-2 rounded-lg bg-indigo-500/10 border border-indigo-500/30">
          <p class="text-indigo-300 font-medium">Option A (AI recommended)</p>
          <p class="text-gray-400 mt-0.5">Move 150 units of SKU-447 from week 12 to week 11 (line has spare capacity). Cost impact: €0.</p>
        </div>
        <div class="p-2 rounded-lg bg-gray-700/40 border border-gray-600">
          <p class="text-gray-300 font-medium">Option B</p>
          <p class="text-gray-400 mt-0.5">Approve overtime on Filling Line 2 for 2 hours. Cost impact: +€320.</p>
        </div>
      </div>`,
    },
    {
      title: 'Commit the Plan',
      desc: 'Once all conflicts are resolved and stakeholders are aligned, lock the plan as the new baseline for the current review cycle. This creates an audit trail.',
      panel: `<p class="text-gray-400 text-xs">🔒 <strong class="text-white">Committing</strong> the plan freezes the current version as the agreed baseline. Any further changes become a new planning cycle or an exception override — both are fully tracked in the audit log.</p>`,
    },
    {
      title: 'Release Orders',
      desc: 'Push planned orders to the execution systems: production orders to the MES/ERP, purchase orders to procurement, transfer orders to the WMS. The plan becomes reality.',
      panel: `<div class="text-xs space-y-1.5">
        <p class="text-white font-medium mb-2">Orders released this cycle:</p>
        <div class="flex items-center justify-between text-gray-400 border-b border-gray-700 pb-1"><span>Production orders</span><span class="text-white">14 orders → ERP</span></div>
        <div class="flex items-center justify-between text-gray-400 border-b border-gray-700 pb-1"><span>Purchase requisitions</span><span class="text-white">8 POs → Procurement</span></div>
        <div class="flex items-center justify-between text-gray-400"><span>Transfer orders</span><span class="text-white">5 transfers → WMS</span></div>
      </div>`,
    },
  ];

  let current = 0;

  function render() {
    const s = STEPS[current];
    (document.getElementById('sw-step-num') as HTMLElement).textContent = String(current + 1);
    (document.getElementById('sw-step-title') as HTMLElement).textContent = s.title;
    (document.getElementById('sw-step-desc') as HTMLElement).textContent = s.desc;
    (document.getElementById('sw-step-panel') as HTMLElement).innerHTML = s.panel;
    (document.getElementById('sw-counter') as HTMLElement).textContent = `${current + 1} / ${STEPS.length}`;

    // Dots
    document.querySelectorAll<HTMLDivElement>('.sw-dot').forEach((dot) => {
      const step = parseInt(dot.dataset.step ?? '0', 10);
      const isActive = step === current;
      const isPast   = step < current;
      dot.style.width = isActive ? '24px' : '8px';
      dot.classList.toggle('bg-sky-500', isActive);
      dot.classList.toggle('bg-sky-800', isPast && !isActive);
      dot.classList.toggle('bg-gray-700', !isActive && !isPast);
    });

    (document.getElementById('sw-prev') as HTMLButtonElement).disabled = current === 0;
    const nextBtn = document.getElementById('sw-next') as HTMLButtonElement;
    if (current === STEPS.length - 1) {
      nextBtn.textContent = 'Done ✓';
      nextBtn.classList.add('text-emerald-400');
      nextBtn.classList.remove('text-sky-400');
    } else {
      nextBtn.innerHTML = `Next <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>`;
      nextBtn.classList.remove('text-emerald-400');
      nextBtn.classList.add('text-sky-400');
    }
  }

  // Hoisted script is bundled into a chunk shared across every topic page; only run
  // when this page actually contains the widget, else top-level DOM access throws
  // and aborts the shared bundle for other widgets.
  if (document.getElementById('sw-prev')) {
    document.getElementById('sw-prev')?.addEventListener('click', () => {
      if (current > 0) { current--; render(); }
    });
    document.getElementById('sw-next')?.addEventListener('click', () => {
      if (current < STEPS.length - 1) { current++; render(); }
    });

    render();
  }
</script>
