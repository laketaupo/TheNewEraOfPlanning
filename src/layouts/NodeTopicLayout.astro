---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

export interface Props {
  title: string;
  description: string;
  summary: string;
  chapterTitle: string;
  chapterSlug: string;
  chapterColor: string;
  topicOrder: number;
  chapterOrder: number;
  prevUrl?: string;
  nextUrl?: string;
  prevTitle?: string;
  nextTitle?: string;
  nodeType: 'item' | 'transformation' | 'transportation' | 'resource';
}

const {
  title,
  description,
  summary,
  chapterTitle,
  chapterSlug,
  chapterColor,
  topicOrder,
  chapterOrder,
  prevUrl,
  nextUrl,
  prevTitle,
  nextTitle,
  nodeType,
} = Astro.props;

const colorMap: Record<string, string> = {
  indigo:  'text-indigo-600 dark:text-indigo-400 border-indigo-400 dark:border-indigo-500',
  violet:  'text-violet-600 dark:text-violet-400 border-violet-400 dark:border-violet-500',
  sky:     'text-sky-600 dark:text-sky-400 border-sky-400 dark:border-sky-500',
  emerald: 'text-emerald-600 dark:text-emerald-400 border-emerald-400 dark:border-emerald-500',
};

const svgColorMap: Record<string, string> = {
  indigo:  'text-indigo-500 dark:text-indigo-400',
  violet:  'text-violet-500 dark:text-violet-400',
  sky:     'text-sky-500 dark:text-sky-400',
  emerald: 'text-emerald-500 dark:text-emerald-400',
};

const dotColorMap: Record<string, string> = {
  indigo:  'bg-indigo-500 dark:bg-indigo-400',
  violet:  'bg-violet-500 dark:bg-violet-400',
  sky:     'bg-sky-500 dark:bg-sky-400',
  emerald: 'bg-emerald-500 dark:bg-emerald-400',
};

const chapterColorClass = colorMap[chapterColor] ?? 'text-brand-600 dark:text-brand-400 border-brand-500';
const svgColor = svgColorMap[chapterColor] ?? 'text-indigo-500 dark:text-indigo-400';
const dotColor = dotColorMap[chapterColor] ?? 'bg-indigo-500';
const topicId = `ch${chapterOrder}-t${topicOrder}`;

const bulletMap: Record<string, string[]> = {
  item: [
    'Has a unique Item ID across the entire network',
    'Classified as raw material, WIP, or finished good',
    'Carries unit of measure, shelf life, and planning horizon',
    'Can be stocked at multiple network locations',
    'Every supply and demand signal in o9 is tied to an item',
  ],
  transformation: [
    'Consumes one or more input items, produces one or more outputs',
    'Defines yield: how much output per unit of input consumed',
    'Has a lead time — the duration of the transformation',
    'Runs at a specific location (plant or manufacturing node)',
    'Can be chained to form multi-level Bills of Materials',
  ],
  transportation: [
    'Moves an item without changing its form or identity',
    'Defines origin node, destination node, and allowed item(s)',
    'Carries transit time, min/max order quantity, and transport mode',
    'Generates transfer orders or shipments in the execution system',
    'Sourcing rules can prioritize lanes — e.g. nearest DC first',
  ],
  resource: [
    'Has available capacity per time bucket (hours or units)',
    'Governed by a calendar: shifts, maintenance, and holidays',
    'Types: machine, labor, storage, or utility',
    'Belongs to a specific location in the network',
    'Consumed by transformation processes via resource consumptions',
  ],
};

const bullets = bulletMap[nodeType] ?? [];
---

<BaseLayout title={`${title} — How o9 Works`} description={description}>
  <!-- Top navigation bar -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
    <a href="/" class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18M3 12l7-7M3 12l7 7"/>
      </svg>
      How o9 Works
    </a>
    <a href={`/chapters/${chapterSlug}`} class={`text-sm font-medium border-b ${chapterColorClass} hover:opacity-80 transition-opacity`}>
      {chapterTitle}
    </a>
    <div class="flex items-center gap-3">
      <div id="topic-progress-display" class="text-xs text-gray-400 dark:text-gray-500"></div>
      <ThemeToggle />
    </div>
  </header>

  <!-- Main content -->
  <main class="min-h-screen pt-16 pb-32 flex flex-col items-center">
    <article class="w-full max-w-5xl px-6 py-12 animate-slide-up">

      <!-- Breadcrumb -->
      <p class={`text-sm font-medium mb-2 ${chapterColorClass.split(' ')[0]}`}>
        Chapter {chapterOrder} · Topic {topicOrder}
      </p>

      <!-- Title -->
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-8 leading-tight">{title}</h1>

      <!-- Two-column: Visual | Characteristics -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">

        <!-- Visual representation -->
        <div class={`rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/40 p-8 flex flex-col items-center justify-center min-h-[260px] ${svgColor}`}>
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-6 self-start">Visual representation</p>

          {nodeType === 'item' && (
            <svg viewBox="0 0 280 165" class="w-full max-w-[240px]" aria-label="Item node — upward triangle">
              <polygon points="140,20 230,140 50,140" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="140" y="160" text-anchor="middle" fill="currentColor" font-size="13" font-family="Inter,sans-serif" opacity="0.6">Item</text>
            </svg>
          )}

          {nodeType === 'transformation' && (
            <svg viewBox="0 0 400 128" class="w-full max-w-[380px]" aria-label="Transformation process — two item triangles connected via a circle">
              {/* Item A: apex(75,15), BL(40,95), BR(110,95) */}
              <polygon points="75,15 110,95 40,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="75" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item A</text>
              {/* Right-edge midpoint of A: (92.5, 55) → circle left (165, 55) */}
              <line x1="93" y1="55" x2="165" y2="55" stroke="currentColor" stroke-width="2"/>
              {/* Circle: center(200,55), r=35 */}
              <circle cx="200" cy="55" r="35" fill="none" stroke="currentColor" stroke-width="2"/>
              <text x="200" y="59" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">BOM</text>
              {/* Circle right (235,55) → left-edge midpoint of B (307.5, 55) */}
              <line x1="235" y1="55" x2="307" y2="55" stroke="currentColor" stroke-width="2"/>
              {/* Item B: apex(325,15), BL(290,95), BR(360,95) */}
              <polygon points="325,15 360,95 290,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="325" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
            </svg>
          )}

          {nodeType === 'transportation' && (
            <svg viewBox="0 0 400 148" class="w-full max-w-[380px]" aria-label="Transportation process — same item at two locations connected via a circle">
              {/* Item B left: apex(75,15), BL(40,95), BR(110,95) */}
              <polygon points="75,15 110,95 40,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="75" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
              <text x="75" y="129" text-anchor="middle" fill="currentColor" font-size="10" font-family="Inter,sans-serif" opacity="0.45">Location 1</text>
              {/* Line */}
              <line x1="93" y1="55" x2="165" y2="55" stroke="currentColor" stroke-width="2"/>
              {/* Circle */}
              <circle cx="200" cy="55" r="35" fill="none" stroke="currentColor" stroke-width="2"/>
              <text x="200" y="59" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">BOD</text>
              {/* Line */}
              <line x1="235" y1="55" x2="307" y2="55" stroke="currentColor" stroke-width="2"/>
              {/* Item B right: same item, different location */}
              <polygon points="325,15 360,95 290,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="325" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
              <text x="325" y="129" text-anchor="middle" fill="currentColor" font-size="10" font-family="Inter,sans-serif" opacity="0.45">Location 2</text>
            </svg>
          )}

          {nodeType === 'resource' && (
            <svg viewBox="0 0 400 198" class="w-full max-w-[380px]" aria-label="Resource — downward triangle connected to top of transformation circle, with two input/output items">
              {/* Resource label above down triangle */}
              <text x="200" y="16" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Resource</text>
              {/* Down triangle: BL(165,25), BR(235,25), apex-down(200,75) */}
              <polygon points="165,25 235,25 200,75" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              {/* Line: resource apex (200,75) → circle top (200,90) */}
              <line x1="200" y1="75" x2="200" y2="90" stroke="currentColor" stroke-width="2"/>
              {/* Circle: center(200,125), r=35 */}
              <circle cx="200" cy="125" r="35" fill="none" stroke="currentColor" stroke-width="2"/>
              <text x="200" y="129" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">BOM</text>
              {/* Item A: apex(75,85), BL(40,165), BR(110,165) */}
              <polygon points="75,85 110,165 40,165" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              {/* Right-edge midpoint of A: (92.5, 125) → circle left (165, 125) */}
              <line x1="93" y1="125" x2="165" y2="125" stroke="currentColor" stroke-width="2"/>
              <text x="75" y="182" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item A</text>
              {/* Item B: apex(325,85), BL(290,165), BR(360,165) */}
              <polygon points="325,85 360,165 290,165" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              {/* Circle right (235,125) → left-edge midpoint of B (307.5, 125) */}
              <line x1="235" y1="125" x2="307" y2="125" stroke="currentColor" stroke-width="2"/>
              <text x="325" y="182" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
            </svg>
          )}
        </div>

        <!-- Characteristics -->
        <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/40 p-6">
          <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-5">Key characteristics</p>
          <ul class="space-y-4">
            {bullets.map((bullet) => (
              <li class="flex items-start gap-3">
                <span class={`mt-2 w-1.5 h-1.5 rounded-full shrink-0 ${dotColor}`}></span>
                <span class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Summary / Description -->
      <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/40 p-6">
        <p class="text-gray-600 dark:text-gray-300 leading-relaxed text-[15px]">{summary}</p>
      </div>

    </article>
  </main>

  <!-- Prev / Next navigation -->
  <nav class="fixed bottom-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4 bg-white/95 dark:bg-gray-950/95 backdrop-blur border-t border-gray-200 dark:border-gray-800">
    <div class="flex-1">
      {prevUrl ? (
        <a href={prevUrl} class="group flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span class="hidden sm:inline">{prevTitle ?? 'Previous'}</span>
          <span class="sm:hidden">Prev</span>
        </a>
      ) : (
        <a href="/" class="group flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18M3 12l7-7M3 12l7 7"/>
          </svg>
          Home
        </a>
      )}
    </div>

    <!-- Topic completion toggle -->
    <button
      id="complete-btn"
      data-topic-id={topicId}
      class="flex items-center gap-2 text-xs font-medium px-3 py-1.5 rounded-full border border-gray-300 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:border-emerald-500 hover:text-emerald-600 dark:hover:text-emerald-400 transition-all"
    >
      <svg id="complete-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span id="complete-label">Mark complete</span>
    </button>

    <div class="flex-1 flex justify-end">
      {nextUrl ? (
        <a href={nextUrl} class="group flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          <span class="hidden sm:inline">{nextTitle ?? 'Next'}</span>
          <span class="sm:hidden">Next</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ) : (
        <a href="/" class="text-sm text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 transition-colors font-medium">
          Finish ✓
        </a>
      )}
    </div>
  </nav>

  <script define:vars={{ topicId }}>
    const STORAGE_KEY = 'o9-progress';

    function getProgress() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
      catch { return {}; }
    }

    function saveProgress(p) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(p));
    }

    const btn = document.getElementById('complete-btn');
    const label = document.getElementById('complete-label');

    function updateBtn(completed) {
      if (completed) {
        btn.classList.remove('border-gray-300', 'dark:border-gray-700', 'text-gray-500', 'dark:text-gray-400');
        btn.classList.add('border-emerald-500', 'text-emerald-600', 'bg-emerald-50', 'dark:bg-emerald-500/10', 'dark:text-emerald-400');
        label.textContent = 'Completed';
      } else {
        btn.classList.add('border-gray-300', 'dark:border-gray-700', 'text-gray-500', 'dark:text-gray-400');
        btn.classList.remove('border-emerald-500', 'text-emerald-600', 'bg-emerald-50', 'dark:bg-emerald-500/10', 'dark:text-emerald-400');
        label.textContent = 'Mark complete';
      }
    }

    const progress = getProgress();
    updateBtn(!!progress[topicId]);

    btn.addEventListener('click', () => {
      const p = getProgress();
      p[topicId] = !p[topicId];
      if (!p[topicId]) delete p[topicId];
      saveProgress(p);
      updateBtn(!!p[topicId]);
    });

    const display = document.getElementById('topic-progress-display');
    if (display) {
      const total = 21;
      const done = Object.values(getProgress()).filter(Boolean).length;
      display.textContent = `${done} / ${total} topics`;
    }
  </script>
</BaseLayout>
