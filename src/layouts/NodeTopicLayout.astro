---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

export interface Props {
  title: string;
  description: string;
  summary: string;
  bullets?: string[];
  nodeLocation?: string;
  lineInLabel?: string;
  lineOutLabel?: string;
  durationLabel?: string;
  transportMode?: string;
  consumptionLabel?: string;
  chapterTitle: string;
  chapterSlug: string;
  chapterUrl: string;
  chapterColor: string;
  topicOrder: number;
  chapterOrder: number;
  prevUrl?: string;
  nextUrl?: string;
  prevTitle?: string;
  nextTitle?: string;
  nodeType: 'item' | 'transformation' | 'transportation' | 'resource';
  pillar?: string;
  totalTopics?: number;
}

const {
  title,
  description,
  summary,
  bullets = [],
  nodeLocation,
  lineInLabel,
  lineOutLabel,
  durationLabel,
  transportMode,
  consumptionLabel,
  chapterTitle,
  chapterSlug,
  chapterUrl,
  chapterColor,
  topicOrder,
  chapterOrder,
  prevUrl,
  nextUrl,
  prevTitle,
  nextTitle,
  nodeType,
  pillar,
  totalTopics,
} = Astro.props;

const pillarBackMap: Record<string, { href: string; label: string }> = {
  technology: { href: `${import.meta.env.BASE_URL}technology/how-planning-software-works`,          label: 'How Planning Software Works' },
  data:       { href: `${import.meta.env.BASE_URL}data/data-driven-planning`,        label: 'Data-Driven Planning' },
  process:    { href: `${import.meta.env.BASE_URL}process/scenario-planning`,        label: 'Scenario Planning' },
  people:     { href: `${import.meta.env.BASE_URL}people/people-and-planning`,       label: 'People & Planning' },
};
const back = pillarBackMap[pillar ?? 'technology'] ?? pillarBackMap.technology;

const colorMap: Record<string, string> = {
  indigo:  'text-indigo-600 dark:text-indigo-400 border-indigo-400 dark:border-indigo-500',
  violet:  'text-violet-600 dark:text-violet-400 border-violet-400 dark:border-violet-500',
  sky:     'text-sky-600 dark:text-sky-400 border-sky-400 dark:border-sky-500',
  emerald: 'text-emerald-600 dark:text-emerald-400 border-emerald-400 dark:border-emerald-500',
};

const svgColorMap: Record<string, string> = {
  indigo:  'text-indigo-500 dark:text-indigo-400',
  violet:  'text-violet-500 dark:text-violet-400',
  sky:     'text-sky-500 dark:text-sky-400',
  emerald: 'text-emerald-500 dark:text-emerald-400',
};

const dotColorMap: Record<string, string> = {
  indigo:  'bg-indigo-500 dark:bg-indigo-400',
  violet:  'bg-violet-500 dark:bg-violet-400',
  sky:     'bg-sky-500 dark:bg-sky-400',
  emerald: 'bg-emerald-500 dark:bg-emerald-400',
};

const chapterColorClass = colorMap[chapterColor] ?? 'text-brand-600 dark:text-brand-400 border-brand-500';
const svgColor = svgColorMap[chapterColor] ?? 'text-indigo-500 dark:text-indigo-400';
const dotColor = dotColorMap[chapterColor] ?? 'bg-indigo-500';
const topicId = `ch${chapterOrder}-t${topicOrder}`;

---

<BaseLayout title={`${title} — ${back.label}`} description={description}>
  <!-- Top navigation bar -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} title="Home" class="flex items-center text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href={back.href} class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18M3 12l7-7M3 12l7 7"/>
        </svg>
        {back.label}
      </a>
    </div>
    <a href={chapterUrl} class={`text-sm font-medium border-b ${chapterColorClass} hover:opacity-80 transition-opacity`}>
      {chapterTitle}
    </a>
    <div class="flex items-center gap-3">
      <div id="topic-progress-display" class="text-xs text-gray-400 dark:text-gray-500"></div>
      <ThemeToggle />
    </div>
  </header>

  <!-- Main content -->
  <main class="min-h-screen pt-16 pb-32 flex flex-col items-center">
    <article class="w-full max-w-5xl px-6 py-7 animate-slide-up">

      <!-- Breadcrumb -->
      <p class={`text-sm font-medium mb-1 ${chapterColorClass.split(' ')[0]}`}>
        Chapter {chapterOrder} · Topic {topicOrder}
      </p>

      <!-- Title -->
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-5 leading-tight">{title}</h1>

      <!-- Two-column: Visual | Characteristics -->
      <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-4 mb-4">

        <!-- Visual representation -->
        <div class={`rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/40 p-12 flex flex-col min-h-[520px] ${svgColor}`}>
          <div class="flex-1 flex items-center justify-center">

          {nodeType === 'item' && (
            <svg viewBox={`0 0 280 ${nodeLocation ? 185 : 165}`} class="w-full" aria-label="Item node — upward triangle">
              <polygon points="140,20 230,140 50,140" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="140" y="158" text-anchor="middle" fill="currentColor" font-size="13" font-family="Inter,sans-serif" opacity="0.6">Item</text>
              {nodeLocation && (
                <text x="140" y="176" text-anchor="middle" fill="currentColor" font-size="11" font-family="Inter,sans-serif" opacity="0.4">{nodeLocation}</text>
              )}
            </svg>
          )}

          {nodeType === 'transformation' && (
            <svg viewBox="0 0 400 128" class="w-full" aria-label="Transformation process — two item triangles connected via a circle">
              {/* Item A: apex(75,15), BL(40,95), BR(110,95) */}
              <polygon points="75,15 110,95 40,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="75" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item A</text>
              {/* Right-edge midpoint of A → circle left */}
              <line x1="93" y1="55" x2="165" y2="55" stroke="currentColor" stroke-width="2"/>
              {lineInLabel && (
                <text x="129" y="47" text-anchor="middle" fill="currentColor" font-size="10" font-family="Inter,sans-serif" opacity="0.5">{lineInLabel}</text>
              )}
              {/* Circle: center(200,55), r=35 */}
              <circle cx="200" cy="55" r="35" fill="none" stroke="currentColor" stroke-width="2"/>
              <text x="200" y="59" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">BOM</text>
              {durationLabel && (
                <text x="200" y="103" text-anchor="middle" fill="currentColor" font-size="11" font-family="Inter,sans-serif" opacity="0.5">{durationLabel}</text>
              )}
              {/* Circle right → left-edge midpoint of B */}
              <line x1="235" y1="55" x2="307" y2="55" stroke="currentColor" stroke-width="2"/>
              {lineOutLabel && (
                <text x="271" y="47" text-anchor="middle" fill="currentColor" font-size="10" font-family="Inter,sans-serif" opacity="0.5">{lineOutLabel}</text>
              )}
              {/* Item B: apex(325,15), BL(290,95), BR(360,95) */}
              <polygon points="325,15 360,95 290,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="325" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
            </svg>
          )}

          {nodeType === 'transportation' && (
            <svg viewBox="0 0 400 148" class="w-full" aria-label="Transportation process — same item at two locations connected via a circle">
              {/* Item B left: apex(75,15), BL(40,95), BR(110,95) */}
              <polygon points="75,15 110,95 40,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="75" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
              <text x="75" y="129" text-anchor="middle" fill="currentColor" font-size="10" font-family="Inter,sans-serif" opacity="0.45">Location 1</text>
              {/* Line */}
              <line x1="93" y1="55" x2="165" y2="55" stroke="currentColor" stroke-width="2"/>
              {/* Circle */}
              <circle cx="200" cy="55" r="35" fill="none" stroke="currentColor" stroke-width="2"/>
              <text x="200" y="59" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">BOD</text>
              {transportMode && (
                <text x="200" y="103" text-anchor="middle" fill="currentColor" font-size="11" font-family="Inter,sans-serif" opacity="0.5">{transportMode}</text>
              )}
              {durationLabel && (
                <text x="200" y="103" text-anchor="middle" fill="currentColor" font-size="11" font-family="Inter,sans-serif" opacity="0.5">{durationLabel}</text>
              )}
              {/* Line */}
              <line x1="235" y1="55" x2="307" y2="55" stroke="currentColor" stroke-width="2"/>
              {/* Item B right: same item, different location */}
              <polygon points="325,15 360,95 290,95" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              <text x="325" y="113" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
              <text x="325" y="129" text-anchor="middle" fill="currentColor" font-size="10" font-family="Inter,sans-serif" opacity="0.45">Location 2</text>
            </svg>
          )}

          {nodeType === 'resource' && (
            <svg viewBox="0 0 400 228" class="w-full" aria-label="Resource — downward triangle connected to top of transformation circle, with two input/output items">
              {/* Resource label above down triangle */}
              <text x="200" y="16" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Resource</text>
              {/* Down triangle: BL(165,25), BR(235,25), apex-down(200,75) */}
              <polygon points="165,25 235,25 200,75" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              {/* Line: resource apex (200,75) → circle top (200,120) — extended for label */}
              <line x1="200" y1="75" x2="200" y2="120" stroke="currentColor" stroke-width="2"/>
              {consumptionLabel && (
                <text x="210" y="101" text-anchor="start" fill="currentColor" font-size="11" font-family="Inter,sans-serif" opacity="0.5">{consumptionLabel}</text>
              )}
              {/* Circle: center(200,155), r=35 */}
              <circle cx="200" cy="155" r="35" fill="none" stroke="currentColor" stroke-width="2"/>
              <text x="200" y="159" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">BOM</text>
              {/* Item A: apex(75,115), BL(40,195), BR(110,195) */}
              <polygon points="75,115 110,195 40,195" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              {/* Right-edge midpoint of A: (92.5, 155) → circle left (165, 155) */}
              <line x1="93" y1="155" x2="165" y2="155" stroke="currentColor" stroke-width="2"/>
              <text x="75" y="212" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item A</text>
              {/* Item B: apex(325,115), BL(290,195), BR(360,195) */}
              <polygon points="325,115 360,195 290,195" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              {/* Circle right (235,155) → left-edge midpoint of B (307.5, 155) */}
              <line x1="235" y1="155" x2="307" y2="155" stroke="currentColor" stroke-width="2"/>
              <text x="325" y="212" text-anchor="middle" fill="currentColor" font-size="12" font-family="Inter,sans-serif" opacity="0.6">Item B</text>
            </svg>
          )}
          </div>
        </div>

        <!-- Characteristics -->
        <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/40 p-6">
          <ul class="space-y-4">
            {bullets.map((bullet) => (
              <li class="flex items-start gap-3">
                <span class={`mt-2 w-1.5 h-1.5 rounded-full shrink-0 ${dotColor}`}></span>
                <span class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Summary / Description -->
      <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/40 p-6">
        <p class="text-gray-600 dark:text-gray-300 leading-relaxed text-[15px]">{summary}</p>
      </div>

    </article>
  </main>

  <!-- Prev / Next navigation -->
  <nav class="fixed bottom-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4 bg-white/95 dark:bg-gray-950/95 backdrop-blur border-t border-gray-200 dark:border-gray-800">
    <div class="flex-1">
      {prevUrl ? (
        <a href={prevUrl} class="group flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span class="hidden sm:inline">{prevTitle ?? 'Previous'}</span>
          <span class="sm:hidden">Prev</span>
        </a>
      ) : (
        <a href={import.meta.env.BASE_URL} class="group flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18M3 12l7-7M3 12l7 7"/>
          </svg>
          Home
        </a>
      )}
    </div>

    <!-- Topic completion toggle -->
    <button
      id="complete-btn"
      data-topic-id={topicId}
      class="flex items-center gap-2 text-xs font-medium px-3 py-1.5 rounded-full border border-gray-300 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:border-emerald-500 hover:text-emerald-600 dark:hover:text-emerald-400 transition-all"
    >
      <svg id="complete-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span id="complete-label">Mark complete</span>
    </button>

    <div class="flex-1 flex justify-end">
      {nextUrl ? (
        <a href={nextUrl} class="group flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
          <span class="hidden sm:inline">{nextTitle ?? 'Next'}</span>
          <span class="sm:hidden">Next</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ) : (
        <a href={import.meta.env.BASE_URL} class="text-sm text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 transition-colors font-medium">
          Finish ✓
        </a>
      )}
    </div>
  </nav>

  <script define:vars={{ topicId, totalTopics }}>
    const STORAGE_KEY = 'platform-progress';

    function getProgress() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
      catch { return {}; }
    }

    function saveProgress(p) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(p));
    }

    const btn = document.getElementById('complete-btn');
    const label = document.getElementById('complete-label');

    function updateBtn(completed) {
      if (completed) {
        btn.classList.remove('border-gray-300', 'dark:border-gray-700', 'text-gray-500', 'dark:text-gray-400');
        btn.classList.add('border-emerald-500', 'text-emerald-600', 'bg-emerald-50', 'dark:bg-emerald-500/10', 'dark:text-emerald-400');
        label.textContent = 'Completed';
      } else {
        btn.classList.add('border-gray-300', 'dark:border-gray-700', 'text-gray-500', 'dark:text-gray-400');
        btn.classList.remove('border-emerald-500', 'text-emerald-600', 'bg-emerald-50', 'dark:bg-emerald-500/10', 'dark:text-emerald-400');
        label.textContent = 'Mark complete';
      }
    }

    const progress = getProgress();
    updateBtn(!!progress[topicId]);

    btn.addEventListener('click', () => {
      const p = getProgress();
      p[topicId] = !p[topicId];
      if (!p[topicId]) delete p[topicId];
      saveProgress(p);
      updateBtn(!!p[topicId]);
    });

    const display = document.getElementById('topic-progress-display');
    if (display) {
      const total = totalTopics ?? 21;
      const done = Object.values(getProgress()).filter(Boolean).length;
      display.textContent = `${done} / ${total} topics`;
    }
  </script>
</BaseLayout>
