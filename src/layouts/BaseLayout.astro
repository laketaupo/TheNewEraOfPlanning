---
import SiteOverlay from '../components/SiteOverlay.astro';
import UserDashboard from '../components/UserDashboard.astro';
import RoleMatrix from '../components/RoleMatrix.astro';
import Search from '../components/Search.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import IntroOverlay from '../components/IntroOverlay.astro';
import { getGlossaryTerms } from '../lib/glossary';
import { getTopics } from '../lib/chapters';
const glossaryTerms = getGlossaryTerms().map(t => ({ term: t.term, aliases: t.aliases, slug: t.slug, definition: t.definition }));
const topicMap = Object.fromEntries(
  getTopics().map(t => [`${t.chapterSlug}/${t.slug}`, { title: t.title, url: t.url }])
);

export interface Props {
  title?: string;
  description?: string;
  hideDashboard?: boolean;
}

const { title = 'How Planning Software Works', description = 'An interactive guide to the Planning software.', hideDashboard = false } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="base-url" content={import.meta.env.BASE_URL} />
    <title>{title}</title>

    <!-- Apply saved theme before render to avoid flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('platform-theme');
        if (t === 'dark')    document.documentElement.classList.add('dark');
        if (t === 'reading') document.documentElement.classList.add('reading');
      })();
    </script>

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-neutral-950 dark:text-neutral-100 font-sans antialiased min-h-screen transition-colors duration-200">
    <slot />
    <SiteOverlay />
    <RoleMatrix />

    <!-- Fixed icon bar (top-right): search · glossary/faq · theme · dashboard -->
    <!-- Must come before <UserDashboard /> so #user-dashboard-btn exists when its inline script runs -->
    <div class="fixed top-2 right-4 z-[55] flex items-center gap-0.5">

      <!-- Search -->
      <div class="relative group/tip">
        <button
          onclick="window.openSearch && window.openSearch()"
          aria-label="Search"
          class="p-2 rounded-lg text-gray-500 hover:text-gray-900 dark:text-neutral-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-neutral-800 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
          </svg>
        </button>
        <span class="pointer-events-none absolute top-full right-0 mt-1.5 whitespace-nowrap rounded-md bg-gray-900 dark:bg-neutral-700 text-white text-[11px] px-2 py-1 opacity-0 group-hover/tip:opacity-100 transition-opacity">Search <kbd class="opacity-60 font-sans">/</kbd></span>
      </div>

      <!-- Glossary/FAQ -->
      <div class="relative group/tip">
        <a
          href={`${import.meta.env.BASE_URL}glossary`}
          aria-label="Open Glossary/FAQ"
          class="p-2 rounded-lg text-gray-500 hover:text-gray-900 dark:text-neutral-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-neutral-800 transition-colors flex"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.247m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.247"/>
          </svg>
        </a>
        <span class="pointer-events-none absolute top-full right-0 mt-1.5 whitespace-nowrap rounded-md bg-gray-900 dark:bg-neutral-700 text-white text-[11px] px-2 py-1 opacity-0 group-hover/tip:opacity-100 transition-opacity">Glossary/FAQ</span>
      </div>

      <!-- Theme toggle -->
      <div class="relative group/tip">
        <ThemeToggle />
        <span class="pointer-events-none absolute top-full right-0 mt-1.5 whitespace-nowrap rounded-md bg-gray-900 dark:bg-neutral-700 text-white text-[11px] px-2 py-1 opacity-0 group-hover/tip:opacity-100 transition-opacity">Theme</span>
      </div>

      <!-- User dashboard (trigger button; panel rendered by UserDashboard.astro) -->
      {!hideDashboard && (
      <div class="relative group/tip">
        <button
          id="user-dashboard-btn"
          aria-label="Your progress dashboard"
          class="relative p-2 rounded-lg text-gray-500 hover:text-gray-900 dark:text-neutral-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-neutral-800 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <span
            id="dash-badge"
            class="hidden absolute -top-1 -right-1 min-w-[16px] h-4 bg-emerald-500 rounded-full text-[9px] text-white font-bold flex items-center justify-center px-1 leading-none pointer-events-none"
          ></span>
        </button>
        <span class="pointer-events-none absolute top-full right-0 mt-1.5 whitespace-nowrap rounded-md bg-gray-900 dark:bg-neutral-700 text-white text-[11px] px-2 py-1 opacity-0 group-hover/tip:opacity-100 transition-opacity">My progress</span>
      </div>
      )}

      <!-- Intro / help -->
      <div class="relative group/tip">
        <button
          onclick="window.openIntro && window.openIntro()"
          aria-label="About this app"
          class="p-2 rounded-lg text-gray-500 hover:text-gray-900 dark:text-neutral-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-neutral-800 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-4M12 8h.01"/>
          </svg>
        </button>
        <span class="pointer-events-none absolute top-full right-0 mt-1.5 whitespace-nowrap rounded-md bg-gray-900 dark:bg-neutral-700 text-white text-[11px] px-2 py-1 opacity-0 group-hover/tip:opacity-100 transition-opacity">About this app</span>
      </div>

    </div>

    {!hideDashboard && <UserDashboard />}
    <IntroOverlay />
    <Search />

    <!-- Glossary tooltip data (injected at build time) -->
    <script type="application/json" id="glossary-data" set:html={JSON.stringify(glossaryTerms)}></script>

    <!-- Topic map for client-side search (injected at build time) -->
    <script type="application/json" id="topic-map" set:html={JSON.stringify(topicMap)}></script>

    <!-- Tooltip container -->
    <div
      id="glossary-tooltip"
      role="tooltip"
      data-placement="bottom"
      class="pointer-events-auto fixed z-[300] hidden max-w-sm rounded-xl border border-gray-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 p-4 shadow-xl"
    >
      <p id="glossary-tooltip-term" class="mb-1 text-sm font-bold text-gray-900 dark:text-white"></p>
      <p id="glossary-tooltip-def" class="text-sm leading-relaxed text-gray-600 dark:text-neutral-300"></p>
      <a id="glossary-tooltip-link" href={`${import.meta.env.BASE_URL}glossary`} class="mt-2 inline-block text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">View in Glossary →</a>
    </div>

    <script is:inline>
    (function () {
      const dataEl = document.getElementById('glossary-data');
      if (!dataEl) return;

      let terms;
      try { terms = JSON.parse(dataEl.textContent); } catch { return; }
      if (!terms || terms.length === 0) return;

      // Build a flat list of { matchStr, slug, definition, term } covering term + aliases
      const matchers = [];
      for (const t of terms) {
        matchers.push({ matchStr: t.term, slug: t.slug, definition: t.definition, term: t.term });
        for (const alias of (t.aliases || [])) {
          matchers.push({ matchStr: alias, slug: t.slug, definition: t.definition, term: t.term });
        }
      }
      // Sort longest match first so multi-word strings win over abbreviations
      matchers.sort((a, b) => b.matchStr.length - a.matchStr.length);

      // Build a single regex that matches any term or alias (case-insensitive, word-boundary)
      const escaped = matchers.map(m => m.matchStr.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
      const pattern = new RegExp('\\b(' + escaped.join('|') + ')\\b', 'gi');

      // Only process [data-pagefind-body] content
      const body = document.querySelector('[data-pagefind-body]');
      if (!body) return;

      function wrapTermsInParagraph(el) {
        const seen = new Set();
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
        const nodes = [];
        let node;
        while ((node = walker.nextNode())) nodes.push(node);

        for (const textNode of nodes) {
          // Skip inside links, code, headings, buttons, or data-no-gloss elements
          let parent = textNode.parentElement;
          while (parent && parent !== el) {
            const tag = parent.tagName;
            if (tag === 'A' || tag === 'CODE' || tag === 'PRE' || tag === 'H1' || tag === 'H2' || tag === 'H3' || tag === 'BUTTON' || parent.hasAttribute('data-no-gloss')) {
              parent = null;
              break;
            }
            parent = parent.parentElement;
          }
          if (parent === null) continue;

          const text = textNode.textContent;
          if (!pattern.test(text)) { pattern.lastIndex = 0; continue; }
          pattern.lastIndex = 0;

          const frag = document.createDocumentFragment();
          let last = 0;
          let match;
          while ((match = pattern.exec(text)) !== null) {
            const matched = match[0];
            const matchedLower = matched.toLowerCase();
            const termDef = matchers.find(m => m.matchStr.toLowerCase() === matchedLower);
            if (!termDef || seen.has(termDef.slug)) continue;
            seen.add(termDef.slug);

            if (match.index > last) {
              frag.appendChild(document.createTextNode(text.slice(last, match.index)));
            }
            const span = document.createElement('span');
            span.className = 'glossary-term';
            span.dataset.slug = termDef.slug;
            span.dataset.def = termDef.definition;
            span.dataset.term = termDef.term;
            span.textContent = matched;
            frag.appendChild(span);
            last = match.index + matched.length;
          }
          pattern.lastIndex = 0;
          if (last === 0) continue;
          if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
          textNode.parentNode.replaceChild(frag, textNode);
        }
      }

      // Process each paragraph and list item separately (first-occurrence-per-paragraph)
      const paragraphs = body.querySelectorAll('p, li');
      paragraphs.forEach(wrapTermsInParagraph);

      // Tooltip show/hide logic (hover-intent: stays open while moving to the card)
      const tooltip = document.getElementById('glossary-tooltip');
      const tooltipTerm = document.getElementById('glossary-tooltip-term');
      const tooltipDef = document.getElementById('glossary-tooltip-def');
      const tooltipLink = document.getElementById('glossary-tooltip-link');
      let hideTimer = null;

      function showTooltip(target) {
        clearTimeout(hideTimer);
        tooltipTerm.textContent = target.dataset.term || '';
        tooltipDef.textContent = target.dataset.def;
        const baseUrl = (document.querySelector('meta[name="base-url"]')?.content || '/').replace(/\/$/, '');
        tooltipLink.href = baseUrl + '/glossary#' + target.dataset.slug;
        tooltip.classList.remove('hidden');
        positionTooltip(target);
      }

      function scheduleHide() {
        clearTimeout(hideTimer);
        hideTimer = setTimeout(function () { tooltip.classList.add('hidden'); }, 200);
      }

      body.addEventListener('mouseover', function (e) {
        const target = e.target.closest('.glossary-term');
        if (!target) return;
        showTooltip(target);
      });

      body.addEventListener('mouseout', function (e) {
        const rel = e.relatedTarget;
        const toTerm = rel && rel.closest && rel.closest('.glossary-term');
        const toTooltip = rel && rel.closest && rel.closest('#glossary-tooltip');
        if (!toTerm && !toTooltip) scheduleHide();
      });

      // Keep open while the pointer is over the card; dismiss when it leaves.
      tooltip.addEventListener('mouseenter', function () { clearTimeout(hideTimer); });
      tooltip.addEventListener('mouseleave', function () { scheduleHide(); });

      function positionTooltip(el) {
        const rect = el.getBoundingClientRect();
        const ttWidth = tooltip.offsetWidth || 340;
        const ttHeight = tooltip.offsetHeight || 100;
        let left = rect.left;
        let top = rect.bottom + 6;
        let placement = 'bottom';
        if (left + ttWidth > window.innerWidth - 12) left = window.innerWidth - ttWidth - 12;
        if (left < 12) left = 12;
        if (top + ttHeight > window.innerHeight - 12) {
          top = rect.top - ttHeight - 6;
          placement = 'top';
        }
        tooltip.dataset.placement = placement;
        tooltip.style.left = left + 'px';
        tooltip.style.top = top + 'px';
      }
    })();
    </script>

    <style is:global>
      /* ── Reading theme ─────────────────────────────────────────────── */
      .reading {
        --reading-bg:              #F7F6F5;
        --reading-surface:         #EEEDEB;
        --reading-surface-high:    #E5E4E2;
        --reading-surface-low:     #F3F2F1;
        --reading-heading:         #1E1D1E;
        --reading-text:            #4A494A;
        --reading-text-muted:      #787678;
        --reading-border:          #ADAAAC;
        --reading-border-strong:   #787678;
        --reading-accent:          #4A494A;
        --reading-accent-hover:    #7A7672;
      }

      .reading body {
        background-color: var(--reading-bg) !important;
        color: var(--reading-text) !important;
      }

      /* Main content area backgrounds — bg-gray-50 intentionally excluded (it's on body) */
      .reading .bg-white,
      .reading .bg-gray-100 {
        background-color: var(--reading-surface-high) !important;
      }

      /* Cards, panels, sidebars */
      .reading .bg-gray-200 { background-color: var(--reading-surface-high) !important; }

      /* Borders */
      .reading .border-gray-200,
      .reading .border-gray-100 { border-color: var(--reading-border) !important; }
      .reading .border-gray-300  { border-color: var(--reading-border-strong) !important; }

      /* Strip gradient clip-text and apply solid colour */
      .reading .bg-clip-text {
        background-image: none !important;
        -webkit-text-fill-color: var(--reading-text) !important;
        color: var(--reading-text) !important;
      }

      /* Override inline style="color:..." accent spans inside headings */
      .reading h1 span,
      .reading h2 span { color: var(--reading-text) !important; }

      /* Text colours */
      .reading h1, .reading h2, .reading h3, .reading h4 { color: var(--reading-heading) !important; }
      .reading .text-gray-900 { color: var(--reading-heading) !important; }
      .reading .text-gray-700,
      .reading .text-gray-800 { color: var(--reading-text) !important; }
      .reading .text-gray-500,
      .reading .text-gray-600 { color: var(--reading-text-muted) !important; }
      .reading .text-gray-400 { color: var(--reading-border-strong) !important; }

      /* Navigation / top bar */
      .reading nav,
      .reading header { background-color: transparent !important; border-color: var(--reading-border) !important; }

      /* Scrollbar */
      .reading ::-webkit-scrollbar { width: 10px; height: 10px; }
      .reading ::-webkit-scrollbar-track  { background: var(--reading-surface-low); }
      .reading ::-webkit-scrollbar-thumb  { background-color: var(--reading-border-strong); border-radius: 5px; border: 2px solid var(--reading-surface-low); }
      .reading ::-webkit-scrollbar-corner { background: var(--reading-surface-low); }

      /* Glossary tooltip */
      .reading #glossary-tooltip {
        background-color: var(--reading-surface) !important;
        border-color: var(--reading-border) !important;
        color: var(--reading-text) !important;
      }

      /* ── Pillar / module / chapter cards ───────────────────────────── */

      /* /themes page theme-cards */
      .reading .theme-people,
      .reading .theme-process,
      .reading .theme-technology,
      .reading .theme-data {
        background: var(--reading-surface-high) !important;
        border-color: var(--reading-border) !important;
        border-top-color: var(--reading-border-strong) !important;
      }
      .reading .theme-people:hover,
      .reading .theme-process:hover,
      .reading .theme-technology:hover,
      .reading .theme-data:hover {
        background: var(--reading-surface) !important;
        box-shadow: 0 6px 24px rgba(120,118,120,0.12) !important;
      }
      .reading .theme-title { color: var(--reading-heading) !important; }
      .reading .theme-desc  { color: var(--reading-text-muted) !important; }
      .reading .theme-people .theme-icon,
      .reading .theme-process .theme-icon,
      .reading .theme-technology .theme-icon,
      .reading .theme-data .theme-icon {
        background: var(--reading-bg) !important;
        color: var(--reading-text-muted) !important;
      }
      .reading .theme-people .theme-badge,
      .reading .theme-process .theme-badge,
      .reading .theme-technology .theme-badge,
      .reading .theme-data .theme-badge {
        background: var(--reading-bg) !important;
        color: var(--reading-text-muted) !important;
      }

      /* Home page lcard */
      .reading .lcard {
        background: var(--reading-surface-high) !important;
        border-color: var(--reading-border) !important;
        border-top-color: var(--reading-border-strong) !important;
        box-shadow: none !important;
      }
      .reading .lcard:hover {
        background: var(--reading-surface) !important;
        box-shadow: 0 6px 24px rgba(120,118,120,0.12) !important;
      }
      .reading .lcard-icon  { background: var(--reading-bg) !important; }
      .reading .lcard-title { color: var(--reading-heading) !important; }
      .reading .lcard-desc  { color: var(--reading-text-muted) !important; }
      .reading .lcard-link  { color: var(--reading-text-muted) !important; }

      /* Pillar index track-cards (scoped styles with hardcoded hex) */
      .reading .track-how-platform,
      .reading .track-bc,
      .reading .track-arch,
      .reading .track-fms,
      .reading .track-fundamentals,
      .reading .track-planning,
      .reading .track-governance,
      .reading .track-process,
      .reading .track-people,
      .reading .track-card {
        background: var(--reading-surface-high) !important;
        border-color: var(--reading-border) !important;
        border-top-color: var(--reading-border-strong) !important;
      }
      .reading .track-card:hover {
        background: var(--reading-surface) !important;
        box-shadow: 0 6px 24px rgba(120,118,120,0.12) !important;
      }
      .reading .track-title { color: var(--reading-heading) !important; }
      .reading .track-desc  { color: var(--reading-text-muted) !important; }
      .reading .track-icon  {
        background: var(--reading-bg) !important;
        color: var(--reading-text-muted) !important;
      }
      .reading .track-badge {
        background: var(--reading-bg) !important;
        color: var(--reading-text-muted) !important;
      }
      .reading .track-badge-soon {
        background: var(--reading-bg) !important;
        color: var(--reading-text-muted) !important;
      }

      /* Module / chapter card Tailwind blue classes */
      .reading .bg-blue-50      { background-color: var(--reading-surface-high) !important; }
      .reading .border-blue-200 { border-color: var(--reading-border) !important; }
      .reading .text-blue-600,
      .reading .text-blue-400   { color: var(--reading-text-muted) !important; }

      /* ── Icon bar hover states ───────────────────────────────────── */
      .reading #theme-picker-menu {
        background-color: var(--reading-surface) !important;
        border-color: var(--reading-border) !important;
      }
      .reading .theme-option:hover {
        background-color: var(--reading-surface-high) !important;
      }
      .reading .theme-option {
        color: var(--reading-text) !important;
      }

      /* ── Scrollbar dark mode ────────────────────────────────────────── */
      .dark ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
      }
      .dark ::-webkit-scrollbar-track {
        background: #2c2c2c; /* neutral-900 */
      }
      .dark ::-webkit-scrollbar-thumb {
        background-color: #404040; /* neutral-700 */
        border-radius: 5px;
        border: 2px solid #2c2c2c;
      }
      .dark ::-webkit-scrollbar-thumb:hover {
        background-color: #525252; /* neutral-600 */
      }
      .dark ::-webkit-scrollbar-corner {
        background: #2c2c2c;
      }

      .glossary-term {
        border-bottom: 1px dotted currentColor;
        cursor: help;
        opacity: 0.9;
      }
      .glossary-term:hover {
        opacity: 1;
      }
      #glossary-tooltip::before {
        content: '';
        position: absolute;
        left: 18px;
        width: 12px;
        height: 12px;
        background-color: inherit;
        border-top: 1px solid;
        border-left: 1px solid;
        border-color: inherit;
      }
      #glossary-tooltip[data-placement='bottom']::before {
        top: -7px;
        transform: rotate(45deg);
      }
      #glossary-tooltip[data-placement='top']::before {
        bottom: -7px;
        transform: rotate(225deg);
      }
    </style>

  <script define:vars={{ BASE_URL: import.meta.env.BASE_URL }}>
    (function () {
      const searchParams = new URLSearchParams(window.location.search);
      const fromParam = searchParams.get('from');
      if (!fromParam) return;

      const basePath = (BASE_URL || '/').replace(/\/$/, '');
      const fromUrl = basePath + '/' + fromParam.replace(/^\//, '');

      // Extract role slug + phase number from "roles/supply-planner/1"
      const rolesMatch = fromParam.match(/^roles\/([^/]+)\/(\d+)$/);
      const roleKey = rolesMatch ? rolesMatch[1] + '/' + rolesMatch[2] : null;

      // Back URL = role overview page (not the phase page)
      const backUrl = rolesMatch ? basePath + '/roles/' + rolesMatch[1] : fromUrl;

      // Retrieve per-page context data injected by topic/chapter layouts
      const chapterPhaseCtx = window.__chapterPhaseCtx || null;
      const topicRoleCtx    = window.__topicRoleCtx    || null;

      // Prefer role title from embedded context, fall back to "Phase N"
      const ctxEntry = roleKey && (
        (chapterPhaseCtx && chapterPhaseCtx.map && chapterPhaseCtx.map[roleKey]) ||
        (topicRoleCtx && topicRoleCtx[roleKey])
      ) || null;
      const roleTitle  = ctxEntry ? ctxEntry.roleTitle : null;
      const fromLabel  = roleTitle || (rolesMatch ? 'Phase ' + rolesMatch[2] : 'Back');

      function setNavLabel(a, longLabel, shortLabel) {
        const spans = a.querySelectorAll('span');
        if (spans.length > 0) {
          spans.forEach(function(s) {
            const cls = s.className.split(' ');
            if (cls.includes('hidden')) s.textContent = longLabel;
            else s.textContent = shortLabel;
          });
        } else {
          const textNodes = Array.from(a.childNodes).filter(function(n) { return n.nodeType === Node.TEXT_NODE; });
          if (textNodes.length > 0) textNodes[0].textContent = longLabel;
          else a.textContent = longLabel;
        }
      }

      // Override header back link → role overview page
      const backLink = document.getElementById('nav-back-link');
      if (backLink) {
        backLink.setAttribute('href', backUrl);
        const textNode = Array.from(backLink.childNodes).find(function(n) {
          return n.nodeType === Node.TEXT_NODE && n.textContent.trim().length > 0;
        });
        if (textNode) textNode.textContent = ' ' + fromLabel;
      }

      // Override chapter index "Back to overview" link → role overview page
      const chapterBackOverview = document.getElementById('chapter-back-overview');
      if (chapterBackOverview) {
        chapterBackOverview.setAttribute('href', backUrl);
        chapterBackOverview.textContent = 'Back to ' + fromLabel;
      }

      // Swap chapter tab bar with phase chapters (chapter index page only)
      if (roleKey && chapterPhaseCtx && chapterPhaseCtx.map) {
        const phaseEntry = chapterPhaseCtx.map[roleKey];
        const tabBar = document.getElementById('chapter-tab-bar');
        if (tabBar && phaseEntry) {
          tabBar.innerHTML = phaseEntry.chapters.map(function(ch, i) {
            const isActive = ch.slug === chapterPhaseCtx.currentChapterSlug;
            const cls = isActive
              ? 'text-xs px-3 py-1 rounded-full transition-colors ' + chapterPhaseCtx.bgClass + ' ' + chapterPhaseCtx.textClass + ' font-medium'
              : 'text-xs px-3 py-1 rounded-full transition-colors text-gray-500 dark:text-neutral-500 hover:text-gray-900 dark:hover:text-neutral-300';
            return '<a href="' + ch.url + '" class="' + cls + '">' + (i + 1) + '. ' + ch.title.replace(/</g, '&lt;') + '</a>';
          }).join('');
        }
      }

      // Handle [data-role-nav] prev/next links on topic pages
      const nav = document.querySelector('[data-role-nav]');
      if (nav) {
        const topicEntry = roleKey && topicRoleCtx ? topicRoleCtx[roleKey] : null;
        const navLinks = Array.from(nav.querySelectorAll('a[href]'));
        const prevA = navLinks[0] || null;
        const nextA = navLinks.length > 1 ? navLinks[navLinks.length - 1] : null;

        if (topicEntry) {
          // Phase-scoped prev: navigate to previous phase topic or back to role page
          if (prevA) {
            if (topicEntry.prevUrl) {
              prevA.setAttribute('href', topicEntry.prevUrl);
              setNavLabel(prevA, topicEntry.prevTitle || 'Previous', 'Prev');
            } else {
              prevA.setAttribute('href', backUrl);
              setNavLabel(prevA, fromLabel, fromLabel);
            }
          }
          // Phase-scoped next: navigate to next phase topic or back to role page at end
          if (nextA && nextA !== prevA) {
            if (topicEntry.nextUrl) {
              nextA.setAttribute('href', topicEntry.nextUrl);
              setNavLabel(nextA, topicEntry.nextTitle || 'Next', 'Next');
            } else {
              nextA.setAttribute('href', backUrl);
              var finishSpan = nextA.querySelector('span');
              if (finishSpan) finishSpan.textContent = 'Complete phase';
              else nextA.textContent = 'Complete phase ✓';
            }
          }
        } else {
          // Fallback: original cross-chapter logic
          var pathParts = window.location.pathname.replace(/\/$/, '').split('/').filter(Boolean);
          var currentChapter = pathParts.length >= 2 ? pathParts[pathParts.length - 2] : null;

          navLinks.forEach(function(a) {
            var href = a.getAttribute('href');
            if (!href) return;
            var cleanHref = href.split('?')[0].replace(/\/$/, '');

            if (cleanHref === basePath || cleanHref === '' || cleanHref === '/') {
              a.setAttribute('href', fromUrl);
              setNavLabel(a, fromLabel, fromLabel);
              return;
            }

            var linkChapter = cleanHref.split('/').filter(Boolean);
            linkChapter = linkChapter.length >= 2 ? linkChapter[linkChapter.length - 2] : null;
            if (currentChapter && linkChapter !== currentChapter) {
              a.setAttribute('href', fromUrl);
              setNavLabel(a, fromLabel, fromLabel);
            } else {
              a.setAttribute('href', cleanHref + '?from=' + encodeURIComponent(fromParam));
            }
          });
        }
      }

      // On chapter index page: propagate ?from= to all topic/start links in main
      var main = document.querySelector('main');
      if (main && !nav) {
        main.querySelectorAll('a[href]').forEach(function(a) {
          if (a.id === 'chapter-back-overview') return;
          var href = a.getAttribute('href');
          if (!href || href.startsWith('http') || href.startsWith('#') || href.startsWith('mailto:')) return;
          var cleanHref = href.split('?')[0];
          a.setAttribute('href', cleanHref + '?from=' + encodeURIComponent(fromParam));
        });
      }
    })();
  </script>

  <!-- H key → navigate home -->
  <script>
    document.addEventListener('keydown', (e) => {
      const t = e.target as HTMLElement;
      if (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable) return;
      if (e.key === 'h' || e.key === 'H') {
        const homeLink = document.querySelector<HTMLAnchorElement>('a[title^="Home"]');
        window.location.href = homeLink ? homeLink.href : (import.meta.env.BASE_URL || '/');
      }
    });
  </script>

  <!-- Topic progress (mark complete / unclear) + auto-advance. No-ops off topic pages. -->
  <script>
    import '../scripts/topic-progress';
  </script>
  </body>
</html>
