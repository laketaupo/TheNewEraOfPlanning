---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRoles, resolveRoleSections, getRoleStats } from '../../lib/roles';

const roles = getRoles().map((role) => {
  const stats = role.comingSoon ? null : getRoleStats(resolveRoleSections(role));
  const halfHours = stats ? Math.round(stats.totalMinutes / 30) * 0.5 : 0;
  return { ...role, stats, hoursLabel: stats ? `~${halfHours} hrs` : '' };
});

const DEPARTMENT_ORDER = [
  'Supply Chain',
  'Finance / Business Control',
  'Product Management',
  'Operations',
  'Sales',
  'Production',
  'Subsidiary',
];

const rolesByDepartment = DEPARTMENT_ORDER.map((dept) => ({
  name: dept,
  roles: roles.filter((r) => r.department === dept),
})).filter((g) => g.roles.length > 0);

const roleColorTextMap: Record<string, string> = {
  indigo:  'text-indigo-600 dark:text-indigo-400',
  violet:  'text-violet-600 dark:text-violet-400',
  sky:     'text-sky-600 dark:text-sky-400',
  emerald: 'text-emerald-600 dark:text-emerald-400',
  amber:   'text-amber-600 dark:text-amber-400',
  teal:    'text-teal-600 dark:text-teal-400',
};
const roleBadgeBgMap: Record<string, string> = {
  indigo:  'bg-indigo-50 dark:bg-neutral-900',
  violet:  'bg-violet-50 dark:bg-neutral-900',
  sky:     'bg-sky-50 dark:bg-neutral-900',
  emerald: 'bg-emerald-50 dark:bg-neutral-900',
  amber:   'bg-amber-50 dark:bg-neutral-900',
  teal:    'bg-teal-50 dark:bg-neutral-900',
};
const roleColorBgMap: Record<string, string> = {
  indigo:  'bg-indigo-50 dark:bg-neutral-900 border-indigo-200 dark:border-indigo-500/30 hover:border-indigo-400 dark:hover:border-indigo-400',
  violet:  'bg-violet-50 dark:bg-neutral-900 border-violet-200 dark:border-violet-500/30 hover:border-violet-400 dark:hover:border-violet-400',
  sky:     'bg-sky-50 dark:bg-neutral-900 border-sky-200 dark:border-sky-500/30 hover:border-sky-400 dark:hover:border-sky-400',
  emerald: 'bg-emerald-50 dark:bg-neutral-900 border-emerald-200 dark:border-emerald-500/30 hover:border-emerald-400 dark:hover:border-emerald-400',
  amber:   'bg-amber-50 dark:bg-neutral-900 border-amber-200 dark:border-amber-500/30 hover:border-amber-400 dark:hover:border-amber-400',
  teal:    'bg-teal-50 dark:bg-neutral-900 border-teal-200 dark:border-teal-500/30 hover:border-teal-400 dark:hover:border-teal-400',
};
const roleIconMap: Record<string, string> = {
  truck:        `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>`,
  beaker:       `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3h6m-6 0v7l-4 9a1 1 0 001 1h12a1 1 0 001-1l-4-9V3"/></svg>`,
  'trending-up':`<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`,
  currency:     `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  briefcase:    `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  chart:        `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
};
---
<BaseLayout title="Learn by Role — Planning Hub">
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3">
    <div class="flex items-center gap-3">
      <a href={`${import.meta.env.BASE_URL}`} title="Home" class="flex h-5 items-center text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        The New Era of Planning
      </a>
    </div>
  </header>

  <div class="relative min-h-screen">
    <!-- Background grid -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#444444_1px,transparent_1px),linear-gradient(to_bottom,#444444_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>

    <div class="relative z-10 px-6 pt-16 pb-20 max-w-3xl mx-auto">

      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-3 tracking-tight">Learn by role</h1>
        <p class="text-gray-500 dark:text-neutral-400 text-lg">A curated learning path with exactly what you need for your position.</p>
      </div>

      <!-- Roles by department -->
      <div class="space-y-10">
        {rolesByDepartment.map(({ name, roles: deptRoles }) => (
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-neutral-500 mb-4">{name}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {deptRoles.map((role) => {
                const textClass  = roleColorTextMap[role.color]  ?? roleColorTextMap.indigo;
                const bgClass    = roleColorBgMap[role.color]    ?? roleColorBgMap.indigo;
                const badgeBg    = roleBadgeBgMap[role.color]    ?? roleBadgeBgMap.indigo;
                const icon       = roleIconMap[role.icon]        ?? roleIconMap.beaker;
                const cardInner  = (
                  <>
                    <div class={`${textClass} mb-3`} set:html={icon} />
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1 leading-snug">{role.title}</h3>
                    <p class="text-xs text-gray-500 dark:text-neutral-400 leading-relaxed mb-4 flex-1">{role.description}</p>
                    {role.stats ? (
                      <span class={`inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 rounded-full self-start ${badgeBg} ${textClass}`}>
                        <span class="role-live-dot"></span>
                        {role.stats.topicCount} topics · {role.hoursLabel}
                      </span>
                    ) : (
                      <span class="inline-flex items-center text-[11px] font-semibold px-2.5 py-1 rounded-full self-start bg-gray-100 dark:bg-neutral-800 text-gray-500 dark:text-neutral-400">Coming soon</span>
                    )}
                  </>
                );
                return role.stats ? (
                  <a href={role.url} class={`group flex flex-col p-5 rounded-2xl border ${bgClass} bg-white dark:bg-neutral-900 transition-all duration-200 hover:-translate-y-1 hover:shadow-xl dark:hover:shadow-2xl no-underline`}>
                    {cardInner}
                  </a>
                ) : (
                  <div class="flex flex-col p-5 rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 opacity-60">
                    {cardInner}
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .role-live-dot {
    @apply w-1.5 h-1.5 rounded-full bg-current;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }
</style>
