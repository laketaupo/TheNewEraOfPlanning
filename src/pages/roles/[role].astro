---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getRoles, resolveRoleSections, getRoleStats, type RoleConfig, type ResolvedRoleSection } from '../../lib/roles';

export async function getStaticPaths() {
  return getRoles()
    .filter((r) => !r.comingSoon)
    .map((role) => ({
      params: { role: role.slug },
      props: { role, sections: resolveRoleSections(role) },
    }));
}

interface Props {
  role: RoleConfig;
  sections: ResolvedRoleSection[];
}

const { role, sections } = Astro.props;
const stats = getRoleStats(sections);
// Round to nearest half hour. Division kept out of the template literal:
// the Astro compiler misparses `/` inside `${...}` here as a regex start.
const halfHours = Math.round(stats.totalMinutes / 30) * 0.5;
const hours = stats.totalMinutes >= 60 ? `~${halfHours} hrs` : `~${stats.totalMinutes} min`;

const colorTextMap: Record<string, string> = {
  indigo: 'text-indigo-600 dark:text-indigo-400',
  violet: 'text-violet-600 dark:text-violet-400',
  sky:    'text-sky-600 dark:text-sky-400',
  emerald:'text-emerald-600 dark:text-emerald-400',
  amber:  'text-amber-600 dark:text-amber-400',
  teal:   'text-teal-600 dark:text-teal-400',
};
const colorBgMap: Record<string, string> = {
  indigo: 'bg-indigo-50 dark:bg-indigo-500/10',
  violet: 'bg-violet-50 dark:bg-violet-500/10',
  sky:    'bg-sky-50 dark:bg-sky-500/10',
  emerald:'bg-emerald-50 dark:bg-emerald-500/10',
  amber:  'bg-amber-50 dark:bg-amber-500/10',
  teal:   'bg-teal-50 dark:bg-teal-500/10',
};
const colorBorderMap: Record<string, string> = {
  indigo: 'border-indigo-200 dark:border-indigo-500/30',
  violet: 'border-violet-200 dark:border-violet-500/30',
  sky:    'border-sky-200 dark:border-sky-500/30',
  emerald:'border-emerald-200 dark:border-emerald-500/30',
  amber:  'border-amber-200 dark:border-amber-500/30',
  teal:   'border-teal-200 dark:border-teal-500/30',
};
const colorDotMap: Record<string, string> = {
  indigo: 'bg-indigo-500',
  violet: 'bg-violet-500',
  sky:    'bg-sky-500',
  emerald:'bg-emerald-500',
  amber:  'bg-amber-500',
  teal:   'bg-teal-500',
};
const colorGradientMap: Record<string, string> = {
  indigo: 'from-indigo-500 to-violet-500',
  violet: 'from-violet-500 to-pink-500',
  sky:    'from-sky-500 to-indigo-500',
  emerald:'from-emerald-500 to-teal-500',
  amber:  'from-amber-500 to-orange-500',
  teal:   'from-teal-500 to-emerald-500',
};

const accentText = colorTextMap[role.color] ?? colorTextMap.indigo;
const accentBg = colorBgMap[role.color] ?? colorBgMap.indigo;
const accentBorder = colorBorderMap[role.color] ?? colorBorderMap.indigo;
const accentDot = colorDotMap[role.color] ?? colorDotMap.indigo;
const accentGradient = colorGradientMap[role.color] ?? colorGradientMap.indigo;

const BASE_URL = import.meta.env.BASE_URL;
---
<BaseLayout title={`${role.title} — Role-based course`} description={role.description}>
  <div class="fixed top-4 right-4 z-50">
    <ThemeToggle />
  </div>

  <div class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <div class="relative z-10 px-6 pt-6 max-w-3xl mx-auto">
      <a href={BASE_URL} class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Home
      </a>
    </div>

    <!-- Hero -->
    <div class="relative z-10 px-6 pt-12 pb-10 max-w-3xl mx-auto text-center animate-fade-in">
      <div class={`inline-flex items-center gap-2 text-xs font-medium ${accentText} ${accentBg} border ${accentBorder} rounded-full px-3 py-1 mb-6`}>
        <span class={`w-1.5 h-1.5 rounded-full ${accentDot} animate-pulse`}></span>
        Role-based course
      </div>

      <h1 class="text-5xl sm:text-6xl font-bold text-gray-900 dark:text-white mb-6 leading-tight tracking-tight">
        <span class={`text-transparent bg-clip-text bg-gradient-to-r ${accentGradient}`}>{role.title}</span>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-xl mx-auto leading-relaxed">
        {role.description}
      </p>
      <p class="text-sm text-gray-400 dark:text-gray-500 mt-4">{stats.topicCount} topics · {hours}</p>
    </div>

    <!-- Progress bar -->
    <div class="relative z-10 px-6 pb-10 max-w-3xl mx-auto">
      <div class="h-2 rounded-full bg-gray-200 dark:bg-gray-800 overflow-hidden">
        <div id="role-progress-fill" class={`h-full rounded-full ${accentDot} transition-all duration-500`} style="width:0%"></div>
      </div>
      <p id="role-progress-text" class="text-sm text-gray-500 dark:text-gray-400 mt-2 text-center">0 of {stats.topicCount} topics completed</p>
    </div>

    <!-- Sections -->
    <main class="relative z-10 max-w-3xl mx-auto px-6 pb-20 animate-slide-up">
      {sections.map((section, si) => (
        <section class={si > 0 ? 'mt-12' : ''}>
          <div class="flex items-baseline gap-3 mb-1">
            <span class={`text-sm font-mono font-bold ${accentText}`}>0{si + 1}</span>
            <h2 class={`text-xs font-bold uppercase tracking-widest ${accentText}`}>{section.title}</h2>
          </div>
          {section.description && (
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 ml-8">{section.description}</p>
          )}
          <ol class="space-y-3">
            {section.topics.map((topic) => (
              <li>
                <a
                  href={topic.url}
                  class={`group flex items-start gap-4 p-4 rounded-xl border ${colorBorderMap[topic.chapterColor] ?? colorBorderMap.indigo} bg-white dark:bg-gray-900/40 hover:bg-gray-50 dark:hover:bg-gray-900/70 transition-all`}
                >
                  <div class="flex-1 min-w-0">
                    <p class="text-gray-900 dark:text-white font-medium">{topic.title}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-500 mt-0.5">{topic.description}</p>
                  </div>
                  <div class="flex items-center gap-3 shrink-0 mt-0.5">
                    <span class={`hidden sm:inline text-xs ${colorTextMap[topic.chapterColor] ?? colorTextMap.indigo} ${colorBgMap[topic.chapterColor] ?? colorBgMap.indigo} px-2 py-0.5 rounded-full whitespace-nowrap`}>
                      {topic.pillarLabel} · {topic.chapterTitle}
                    </span>
                    <span class="text-xs text-gray-400 dark:text-gray-600">{topic.estimatedMinutes} min</span>
                    <span
                      class="topic-completion-dot w-2 h-2 rounded-full bg-gray-200 dark:bg-gray-700 transition-colors"
                      data-topic-id={topic.topicId}
                    ></span>
                  </div>
                </a>
              </li>
            ))}
          </ol>
        </section>
      ))}

      <!-- Start course CTA -->
      <div class="mt-12 flex items-center gap-4">
        <a
          href={sections[0]?.topics[0]?.url ?? BASE_URL}
          class={`inline-flex items-center gap-2 ${accentBg} ${accentText} font-semibold px-5 py-2.5 rounded-xl border ${accentBorder} hover:opacity-90 transition-opacity`}
        >
          Start course
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={BASE_URL} class="text-sm text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">Back to overview</a>
      </div>
    </main>
  </div>

  <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-600">
    <p>Built with Astro · Content in Markdown · Maintained with Claude</p>
  </footer>
</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(20,184,166,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(20,184,166,0.15), transparent);
  }
</style>

<script>
  const STORAGE_KEY = 'o9-progress';
  function getProgress(): Record<string, boolean> {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
    catch { return {}; }
  }
  const progress = getProgress();
  const dots = document.querySelectorAll<HTMLSpanElement>('.topic-completion-dot');
  let done = 0;
  dots.forEach((dot) => {
    const id = dot.dataset.topicId ?? '';
    if (progress[id]) {
      done++;
      dot.classList.remove('bg-gray-200', 'dark:bg-gray-700');
      dot.classList.add('bg-emerald-500');
    }
  });
  const fill = document.getElementById('role-progress-fill');
  const text = document.getElementById('role-progress-text');
  if (fill && dots.length > 0) fill.style.width = `${Math.round((done / dots.length) * 100)}%`;
  if (text) text.textContent = `${done} of ${dots.length} topics completed`;
</script>
