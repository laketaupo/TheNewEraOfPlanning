---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ThemeToggle from '../../../components/ThemeToggle.astro';
import { getRoles, resolveRolePhases, getRoleStats, resolveRoleSections, type RoleConfig, type ResolvedRolePhase } from '../../../lib/roles';

export async function getStaticPaths() {
  const paths: { params: { role: string; phase: string }; props: any }[] = [];
  for (const role of getRoles().filter((r) => !r.comingSoon && r.phases)) {
    const phases = resolveRolePhases(role)!;
    phases.forEach((phase, pi) => {
      if (!phase.isEmpty) {
        paths.push({
          params: { role: role.slug, phase: String(pi + 1) },
          props: { role, phase, phaseIndex: pi, totalPhases: phases.length, phases },
        });
      }
    });
  }
  return paths;
}

interface Props {
  role: RoleConfig;
  phase: ResolvedRolePhase;
  phaseIndex: number;
  totalPhases: number;
  phases: ResolvedRolePhase[];
}

const { role, phase, phaseIndex, totalPhases, phases } = Astro.props;

const phaseTopics = phase.sections.flatMap((s) => s.topics);
const phaseMins = phaseTopics.reduce((sum, t) => sum + t.estimatedMinutes, 0);
const phaseHalfHours = Math.round(phaseMins / 30) * 0.5;
const phaseTime = phaseMins >= 60 ? `~${phaseHalfHours} hrs` : `~${phaseMins} min`;

// Navigate only among non-empty phases
const nonEmptyIndices = phases.map((p, i) => (!p.isEmpty ? i : -1)).filter((i) => i >= 0);
const posInNonEmpty = nonEmptyIndices.indexOf(phaseIndex);
const prevPhaseIdx = posInNonEmpty > 0 ? nonEmptyIndices[posInNonEmpty - 1] : null;
const nextPhaseIdx =
  posInNonEmpty < nonEmptyIndices.length - 1 ? nonEmptyIndices[posInNonEmpty + 1] : null;

const BASE_URL = import.meta.env.BASE_URL;
const prevPhaseUrl = prevPhaseIdx !== null ? `${BASE_URL}roles/${role.slug}/${prevPhaseIdx + 1}` : null;
const nextPhaseUrl = nextPhaseIdx !== null ? `${BASE_URL}roles/${role.slug}/${nextPhaseIdx + 1}` : null;
const nextPhaseTitle = nextPhaseIdx !== null ? phases[nextPhaseIdx].title : null;
const nextPhaseNumber = nextPhaseIdx !== null ? nextPhaseIdx + 1 : null;

const colorTextMap: Record<string, string> = {
  indigo: 'text-indigo-600 dark:text-indigo-400',
  violet: 'text-violet-600 dark:text-violet-400',
  sky:    'text-sky-600 dark:text-sky-400',
  emerald:'text-emerald-600 dark:text-emerald-400',
  amber:  'text-amber-600 dark:text-amber-400',
  teal:   'text-teal-600 dark:text-teal-400',
};
const colorBgMap: Record<string, string> = {
  indigo: 'bg-indigo-50 dark:bg-indigo-500/10',
  violet: 'bg-violet-50 dark:bg-violet-500/10',
  sky:    'bg-sky-50 dark:bg-sky-500/10',
  emerald:'bg-emerald-50 dark:bg-emerald-500/10',
  amber:  'bg-amber-50 dark:bg-amber-500/10',
  teal:   'bg-teal-50 dark:bg-teal-500/10',
};
const colorBorderMap: Record<string, string> = {
  indigo: 'border-indigo-200 dark:border-indigo-500/30',
  violet: 'border-violet-200 dark:border-violet-500/30',
  sky:    'border-sky-200 dark:border-sky-500/30',
  emerald:'border-emerald-200 dark:border-emerald-500/30',
  amber:  'border-amber-200 dark:border-amber-500/30',
  teal:   'border-teal-200 dark:border-teal-500/30',
};
const colorDotMap: Record<string, string> = {
  indigo: 'bg-indigo-500',
  violet: 'bg-violet-500',
  sky:    'bg-sky-500',
  emerald:'bg-emerald-500',
  amber:  'bg-amber-500',
  teal:   'bg-teal-500',
};
const colorGradientMap: Record<string, string> = {
  indigo: 'from-indigo-500 to-violet-500',
  violet: 'from-violet-500 to-pink-500',
  sky:    'from-sky-500 to-indigo-500',
  emerald:'from-emerald-500 to-teal-500',
  amber:  'from-amber-500 to-orange-500',
  teal:   'from-teal-500 to-emerald-500',
};
const colorBarMap: Record<string, string> = {
  indigo: 'bg-indigo-500',
  violet: 'bg-violet-500',
  sky:    'bg-sky-500',
  emerald:'bg-emerald-500',
  amber:  'bg-amber-500',
  teal:   'bg-teal-500',
};

const accentText     = colorTextMap[role.color]   ?? colorTextMap.indigo;
const accentBg       = colorBgMap[role.color]     ?? colorBgMap.indigo;
const accentBorder   = colorBorderMap[role.color] ?? colorBorderMap.indigo;
const accentDot      = colorDotMap[role.color]    ?? colorDotMap.indigo;
const accentBar      = colorBarMap[role.color]    ?? colorBarMap.indigo;
const accentGradient = colorGradientMap[role.color] ?? colorGradientMap.indigo;

const topicIds = phaseTopics.map((t) => t.topicId);
---
<BaseLayout
  title={`Phase ${phaseIndex + 1}: ${phase.title} — ${role.title}`}
  description={phase.goal}
>
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-3 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-3">
      <a href={BASE_URL} title="Home" class="flex h-5 items-center text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href={`${BASE_URL}roles/${role.slug}`} class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        {role.title}
      </a>
    </div>
    <ThemeToggle />
  </header>

  <div class="relative overflow-hidden pt-12">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <!-- Hero -->
    <div class="relative z-10 px-6 pt-12 pb-8 max-w-3xl mx-auto text-center animate-fade-in">
      <div class={`inline-flex items-center gap-2 text-xs font-medium ${accentText} ${accentBg} border ${accentBorder} rounded-full px-3 py-1 mb-6`}>
        <span class={`w-1.5 h-1.5 rounded-full ${accentDot} animate-pulse`}></span>
        Phase {phaseIndex + 1} of {totalPhases}
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4 leading-tight tracking-tight">
        <span class={`text-transparent bg-clip-text bg-gradient-to-r ${accentGradient}`}>{phase.title}</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl mx-auto leading-relaxed">
        {phase.goal}
      </p>
      <p class="text-sm text-gray-400 dark:text-gray-500 mt-4">{phaseTopics.length} topics · {phaseTime}</p>
    </div>

    <!-- Phase meta: key areas + behaviors -->
    <div class="relative z-10 px-6 pb-8 max-w-3xl mx-auto animate-fade-in">
      <div class={`rounded-2xl border ${accentBorder} ${accentBg} p-5 grid sm:grid-cols-2 gap-6`}>
        <div>
          <p class={`text-xs font-bold uppercase tracking-widest ${accentText} mb-3`}>Key areas</p>
          <ul class="space-y-2">
            {phase.keyAreas.map((area) => (
              <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
                <span class={`mt-1.5 w-1.5 h-1.5 rounded-full ${accentDot} shrink-0`}></span>
                {area}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class={`text-xs font-bold uppercase tracking-widest ${accentText} mb-3`}>Characteristic behavior</p>
          <ul class="space-y-2">
            {phase.behaviors.map((b) => (
              <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
                <span class={`mt-1.5 w-1.5 h-1.5 rounded-full ${accentDot} shrink-0`}></span>
                {b}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Phase progress bar -->
    <div class="relative z-10 px-6 pb-10 max-w-3xl mx-auto">
      <div class="h-2 rounded-full bg-gray-200 dark:bg-gray-800 overflow-hidden">
        <div id="phase-progress-fill" class={`h-full rounded-full ${accentBar} transition-all duration-500`} style="width:0%"></div>
      </div>
      <p id="phase-progress-text" class="text-sm text-gray-500 dark:text-gray-400 mt-2 text-center">0 of {phaseTopics.length} topics completed</p>
    </div>

    <!-- Chapter cards -->
    <main class="relative z-10 max-w-3xl mx-auto px-6 pb-20 animate-slide-up">
      <div class="space-y-3">
        {phase.sections.map((section, si) => {
          const firstTopic = section.topics[0];
          const chapterUrl = firstTopic?.chapterUrl;
          const cc = firstTopic?.chapterColor ?? role.color;
          const pillarLabel = firstTopic?.pillarLabel ?? '';
          const totalMins = section.topics.reduce((s: number, t: any) => s + t.estimatedMinutes, 0);
          const halfH = Math.round(totalMins / 30) * 0.5;
          const time = totalMins >= 60 ? `~${halfH} hrs` : `~${totalMins} min`;
          const chapterTopicIds = section.topics.map((t: any) => t.topicId).join(',');
          return (
            <a
              href={`${chapterUrl}?from=roles/${role.slug}/${phaseIndex + 1}`}
              class={`block p-5 rounded-2xl border ${colorBorderMap[cc] ?? colorBorderMap.indigo} bg-white dark:bg-gray-900/40 hover:bg-gray-50 dark:hover:bg-gray-900/70 transition-all`}
              data-chapter-topic-ids={chapterTopicIds}
            >
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-mono font-bold text-gray-400 dark:text-gray-600">{String(si + 1).padStart(2, '0')}</span>
                  <span class={`text-xs font-medium ${colorTextMap[cc] ?? colorTextMap.indigo} ${colorBgMap[cc] ?? colorBgMap.indigo} px-2 py-0.5 rounded-full`}>
                    {pillarLabel}
                  </span>
                </div>
                <span class="text-xs text-gray-400 dark:text-gray-500">{section.topics.length} topics · {time}</span>
              </div>
              <h2 class="text-base font-semibold text-gray-900 dark:text-white mb-1">{section.title}</h2>
              {section.description && (
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{section.description}</p>
              )}
              <div class="flex items-center gap-3 mt-4">
                <div class="flex-1 h-1.5 rounded-full bg-gray-100 dark:bg-gray-800 overflow-hidden">
                  <div class={`chapter-progress-bar h-full rounded-full ${colorBarMap[cc] ?? colorBarMap.indigo} transition-all duration-500`} style="width:0%"></div>
                </div>
                <span class="chapter-progress-text text-xs text-gray-400 dark:text-gray-500 shrink-0 w-12 text-right">
                  0 / {section.topics.length}
                </span>
                <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 ${colorTextMap[cc] ?? colorTextMap.indigo} shrink-0`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Navigation -->
      <div class="mt-12 flex items-center justify-between gap-4 flex-wrap">
        <div class="flex items-center gap-4">
          <a
            href={`${phase.sections[0]?.topics[0]?.chapterUrl ?? BASE_URL}?from=roles/${role.slug}/${phaseIndex + 1}`}
            class={`inline-flex items-center gap-2 ${accentBg} ${accentText} font-semibold px-5 py-2.5 rounded-xl border ${accentBorder} hover:opacity-90 transition-opacity`}
          >
            Start phase
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
          <a href={`${BASE_URL}roles/${role.slug}`} class="text-sm text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
            All phases
          </a>
        </div>

        {nextPhaseUrl && (
          <a
            href={nextPhaseUrl}
            class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
          >
            <span>Phase {nextPhaseNumber}: {nextPhaseTitle}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        )}
      </div>
    </main>
  </div>

  <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-600">
    <p>Built with Astro · Content in Markdown · Maintained with Claude</p>
  </footer>
</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(20,184,166,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(20,184,166,0.15), transparent);
  }
</style>

<script define:vars={{ topicIds }}>
  const STORAGE_KEY = 'platform-progress';
  function getProgress() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
    catch { return {}; }
  }
  const progress = getProgress();

  // Overall phase progress bar
  const done = topicIds.filter((id) => progress[id]).length;
  const fill = document.getElementById('phase-progress-fill');
  const text = document.getElementById('phase-progress-text');
  if (fill && topicIds.length > 0) fill.style.width = `${Math.round((done / topicIds.length) * 100)}%`;
  if (text) text.textContent = `${done} of ${topicIds.length} topics completed`;

  // Per-chapter progress bars
  document.querySelectorAll('[data-chapter-topic-ids]').forEach((card) => {
    const ids = (card.dataset.chapterTopicIds ?? '').split(',').filter(Boolean);
    const chapterDone = ids.filter((id) => progress[id]).length;
    const bar = card.querySelector('.chapter-progress-bar');
    const label = card.querySelector('.chapter-progress-text');
    if (bar && ids.length > 0) bar.style.width = `${Math.round((chapterDone / ids.length) * 100)}%`;
    if (label) label.textContent = `${chapterDone} / ${ids.length}`;
  });
</script>
