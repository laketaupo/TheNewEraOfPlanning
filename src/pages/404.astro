---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Redirecting… — How o9 Works" description="">
  <script define:vars={{ base }}>
    // If the visitor landed outside the base path, send them there immediately.
    if (!window.location.pathname.startsWith(base)) {
      window.location.replace(base + '/');
    }
  </script>
  <div class="min-h-screen flex flex-col items-center justify-center text-center px-6">
    <p class="text-sm text-gray-400 mb-2">Redirecting…</p>
    <a href={base + '/'} class="text-indigo-500 hover:underline text-sm">
      Go to {base}/
    </a>
  </div>
</BaseLayout>
