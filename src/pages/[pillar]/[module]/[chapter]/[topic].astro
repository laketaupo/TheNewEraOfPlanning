---
import TopicLayout from '../../../../layouts/TopicLayout.astro';
import NodeTopicLayout from '../../../../layouts/NodeTopicLayout.astro';
import CardGridLayout from '../../../../layouts/CardGridLayout.astro';
import DataTableLayout from '../../../../layouts/DataTableLayout.astro';
import ComparisonLayout from '../../../../layouts/ComparisonLayout.astro';
import FullWidthWidgetLayout from '../../../../layouts/FullWidthWidgetLayout.astro';
import RasciTableLayout from '../../../../layouts/RasciTableLayout.astro';
import ProcessStepDetailLayout from '../../../../layouts/ProcessStepDetailLayout.astro';
import WhatIfWidget from '../../../../components/sim/WhatIfWidget.astro';
import DemandSlicingWidget from '../../../../components/sim/DemandSlicingWidget.astro';
import VarietyDisaggWidget from '../../../../components/sim/VarietyDisaggWidget.astro';
import SeasonalDisaggWidget from '../../../../components/sim/SeasonalDisaggWidget.astro';
import OrgChart from '../../../../components/widgets/OrgChart.astro';
import DemandShockSim from '../../../../components/sim/DemandShockSim.astro';
import StepWalkthrough from '../../../../components/sim/StepWalkthrough.astro';
import InteractiveGraph from '../../../../components/sim/InteractiveGraph.astro';
import DemandFlowGraph from '../../../../components/sim/DemandFlowGraph.astro';
import SupplyFlowGraph from '../../../../components/sim/SupplyFlowGraph.astro';
import { getChapters, getTopics, getAdjacentTopics } from '../../../../lib/chapters';

// Build static paths for all topics
export async function getStaticPaths() {
  const allTopics = getTopics();
  const chapters = getChapters();

  return allTopics
    .filter(t => {
      const ch = chapters.find(c => c.slug === t.chapterSlug);
      return ch?.module && !ch.hidden;
    })
    .map((topic) => {
      const chapter = chapters.find((c) => c.slug === topic.chapterSlug)!;
      const [prev, next] = getAdjacentTopics(topic.url);
      const totalTopics = allTopics.filter((t) => t.pillar === topic.pillar).length;
      return {
        params: { pillar: topic.pillar, module: chapter.module, chapter: topic.chapterSlug, topic: topic.slug },
        props: { topic, chapter, prev, next, totalTopics },
      };
    });
}

const { topic, chapter, prev, next, totalTopics } = Astro.props;

// Dynamically import the MDX file for this topic
const mdxFiles = import.meta.glob('../../../../content/chapters/**/*.md', { eager: false });
const mdxKey = Object.keys(mdxFiles).find((k) =>
  k.endsWith(`/${topic.chapterSlug}/${topic.slug}.md`)
);
const { Content } = mdxKey ? await mdxFiles[mdxKey]() as any : { Content: null };

const layout = topic.topicLayout ?? 'topic';

const sharedProps = {
  title: topic.title,
  description: topic.description,
  chapterTitle: chapter.title,
  chapterSlug: chapter.slug,
  chapterColor: chapter.color,
  chapterUrl: topic.chapterUrl,
  topicOrder: topic.order,
  topicSlug: topic.slug,
  chapterOrder: chapter.order,
  prevUrl: prev?.url,
  nextUrl: next?.url,
  prevTitle: prev?.title,
  nextTitle: next?.title,
  pillar: topic.pillar ?? 'technology',
  module: topic.module ?? 'planning-software',
  totalTopics,
};
---

{layout === 'node-topic' ? (
  <NodeTopicLayout
    {...sharedProps}
    summary={topic.summary ?? ''}
    nodeType={topic.nodeType as any}
    bullets={topic.bullets ?? []}
    nodeLocation={topic.nodeLocation}
    lineInLabel={topic.lineInLabel}
    lineOutLabel={topic.lineOutLabel}
    durationLabel={topic.durationLabel}
    transportMode={topic.transportMode}
    consumptionLabel={topic.consumptionLabel}
  />
) : layout === 'card-grid' ? (
  <CardGridLayout
    {...sharedProps}
    cards={topic.cards}
  />
) : layout === 'data-table' ? (
  <DataTableLayout
    {...sharedProps}
    tableColumns={topic.tableColumns}
    tableRows={topic.tableRows}
  />
) : layout === 'comparison' ? (
  <ComparisonLayout
    {...sharedProps}
    left={topic.left}
    right={topic.right}
  />
) : layout === 'full-widget' ? (
  <FullWidthWidgetLayout
    {...sharedProps}
    widget={topic.widget}
  >
    {Content && <Content />}
    <Fragment slot="widget">
      {topic.widget === 'what-if' && <WhatIfWidget />}
      {topic.widget === 'demand-shock' && <DemandShockSim />}
      {topic.widget === 'walkthrough' && <StepWalkthrough />}
      {topic.widget === 'graph' && <InteractiveGraph step={topic.widgetStep} />}
      {topic.widget === 'demand-flow' && <DemandFlowGraph />}
      {topic.widget === 'supply-flow' && <SupplyFlowGraph />}
      {topic.widget === 'org-chart' && <OrgChart orgChart={topic.orgChart} />}
      {topic.widget === 'demand-slicing' && <DemandSlicingWidget />}
      {topic.widget === 'variety-disagg' && <VarietyDisaggWidget />}
      {topic.widget === 'seasonal-disagg' && <SeasonalDisaggWidget />}
    </Fragment>
  </FullWidthWidgetLayout>
) : layout === 'process-step-detail' ? (
  <ProcessStepDetailLayout
    {...sharedProps}
    inputs={topic.inputs}
    outputs={topic.outputs}
    roles={topic.roles}
    systems={topic.systems}
    tasks={topic.tasks}
  />
) : layout === 'rasci-table' ? (
  <RasciTableLayout
    {...sharedProps}
    roles={topic.roles}
    steps={topic.steps}
  />
) : (
  <TopicLayout
    {...sharedProps}
    widget={topic.widget}
  >
    {Content && <Content />}
    <Fragment slot="widget">
      {topic.widget === 'what-if' && <WhatIfWidget />}
      {topic.widget === 'demand-shock' && <DemandShockSim />}
      {topic.widget === 'walkthrough' && <StepWalkthrough />}
      {topic.widget === 'graph' && <InteractiveGraph step={topic.widgetStep} />}
      {topic.widget === 'demand-flow' && <DemandFlowGraph />}
      {topic.widget === 'supply-flow' && <SupplyFlowGraph />}
    </Fragment>
  </TopicLayout>
)}
