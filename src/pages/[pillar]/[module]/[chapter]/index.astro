---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getChapters, getTopicsForChapter, getChapterUrl } from '../../../../lib/chapters';
import { getRoles, resolveRolePhases } from '../../../../lib/roles';

export async function getStaticPaths() {
  const chapters = getChapters();
  return chapters
    .filter(ch => ch.module && !ch.hidden)
    .map((ch) => ({ params: { pillar: ch.pillar, module: ch.module, chapter: ch.slug } }));
}

const { chapter: chapterSlug } = Astro.params;
const chapters = getChapters();
const chapter = chapters.find((c) => c.slug === chapterSlug)!;
const topics = getTopicsForChapter(chapterSlug);

const colorTextMap: Record<string, string> = {
  indigo:  'text-indigo-600 dark:text-indigo-400',
  violet:  'text-violet-600 dark:text-violet-400',
  sky:     'text-sky-600 dark:text-sky-400',
  emerald: 'text-emerald-600 dark:text-emerald-400',
  amber:   'text-amber-600 dark:text-amber-400',
  teal:    'text-teal-600 dark:text-teal-400',
  yellow:  'text-yellow-600 dark:text-yellow-400',
  blue:    'text-blue-600 dark:text-blue-400',
  red:     'text-red-600 dark:text-red-400',
};
const colorBorderMap: Record<string, string> = {
  indigo:  'border-indigo-200 dark:border-indigo-500/40 hover:border-indigo-400',
  violet:  'border-violet-200 dark:border-violet-500/40 hover:border-violet-400',
  sky:     'border-sky-200 dark:border-sky-500/40 hover:border-sky-400',
  emerald: 'border-emerald-200 dark:border-emerald-500/40 hover:border-emerald-400',
  amber:   'border-amber-200 dark:border-amber-500/40 hover:border-amber-400',
  teal:    'border-teal-200 dark:border-teal-500/40 hover:border-teal-400',
  yellow:  'border-yellow-200 dark:border-yellow-500/40 hover:border-yellow-400',
  blue:    'border-blue-200 dark:border-blue-500/40 hover:border-blue-400',
  red:     'border-red-200 dark:border-red-500/40 hover:border-red-400',
};
const colorBgMap: Record<string, string> = {
  indigo:  'bg-indigo-50 dark:bg-neutral-900',
  violet:  'bg-violet-50 dark:bg-neutral-900',
  sky:     'bg-sky-50 dark:bg-neutral-900',
  emerald: 'bg-emerald-50 dark:bg-neutral-900',
  amber:   'bg-amber-50 dark:bg-neutral-900',
  teal:    'bg-teal-50 dark:bg-neutral-900',
  yellow:  'bg-yellow-50 dark:bg-neutral-900',
  blue:    'bg-blue-50 dark:bg-neutral-900',
  red:     'bg-red-50 dark:bg-neutral-900',
};

const BASE_URL = import.meta.env.BASE_URL;
const moduleBackMap: Record<string, { href: string; label: string }> = {
  'planning-software':         { href: `${BASE_URL}technology/planning-software`,         label: 'Planning Software' },
  'erp':                  { href: `${BASE_URL}technology/erp`,     label: 'ERP' },
  'architecture':         { href: `${BASE_URL}technology/architecture`,         label: 'Architecture & Integration' },
  'mdm':                  { href: `${BASE_URL}technology/mdm`,                  label: 'MDM Tool' },
  'fms':                  { href: `${BASE_URL}technology/fms`,                  label: 'FMS Tool' },
  'data-driven-planning': { href: `${BASE_URL}data/data-driven-planning`,       label: 'Data-Driven Planning' },
  'data-fundamentals':    { href: `${BASE_URL}data/data-fundamentals`,          label: 'Data Fundamentals' },
  'data-governance':      { href: `${BASE_URL}data/data-governance`,            label: 'Data Governance' },
  'reporting':            { href: `${BASE_URL}technology/reporting`,            label: 'Reporting' },
  'process-fundamentals': { href: `${BASE_URL}process/process-fundamentals`,     label: 'Process Fundamentals' },
  'scenario-planning':    { href: `${BASE_URL}process/scenario-planning`,       label: 'Scenario Planning' },
  'sop-process':          { href: `${BASE_URL}process/sop-process`,             label: 'S&OP' },
  'soe-process':          { href: `${BASE_URL}process/soe-process`,             label: 'S&OE' },
  'execution-process':    { href: `${BASE_URL}process/execution-process`,       label: 'Execution' },
  'organisation':               { href: `${BASE_URL}people/organisation`,               label: 'Organisation' },
  'roles-and-responsibilities': { href: `${BASE_URL}people/roles-and-responsibilities`, label: 'Roles & Responsibilities' },
};
const pillar = chapter.pillar ?? 'technology';
const currentModule = chapter.module ?? Astro.params.module ?? 'planning-software';
const back = moduleBackMap[currentModule] ?? { href: `${BASE_URL}${pillar}/${currentModule}`, label: currentModule };
const pillarChapters = getChapters(pillar).filter(c => !c.hidden && c.module === Astro.params.module);

const colorGradientMap: Record<string, { light: string; dark: string }> = {
  indigo:  { light: 'rgba(99,102,241,0.08)',   dark: 'rgba(99,102,241,0.15)' },
  violet:  { light: 'rgba(139,92,246,0.08)',   dark: 'rgba(139,92,246,0.15)' },
  sky:     { light: 'rgba(14,165,233,0.08)',   dark: 'rgba(14,165,233,0.15)' },
  emerald: { light: 'rgba(16,185,129,0.08)',   dark: 'rgba(16,185,129,0.15)' },
  amber:   { light: 'rgba(245,158,11,0.08)',   dark: 'rgba(245,158,11,0.15)' },
  teal:    { light: 'rgba(20,184,166,0.08)',   dark: 'rgba(20,184,166,0.15)' },
  yellow:  { light: 'rgba(234,179,8,0.08)',    dark: 'rgba(234,179,8,0.15)' },
  blue:    { light: 'rgba(59,130,246,0.08)',   dark: 'rgba(59,130,246,0.15)' },
  red:     { light: 'rgba(239,68,68,0.08)',    dark: 'rgba(239,68,68,0.15)' },
};
const gradientColor = colorGradientMap[chapter.color] ?? { light: 'rgba(16,185,129,0.08)', dark: 'rgba(16,185,129,0.15)' };

const textClass = colorTextMap[chapter.color] ?? 'text-brand-600 dark:text-brand-400';
const borderClass = colorBorderMap[chapter.color] ?? 'border-brand-200 dark:border-brand-500/40';
const bgClass = colorBgMap[chapter.color] ?? 'bg-brand-50 dark:bg-neutral-900';

// Build per-role-phase chapter lists so the client can swap the tab bar when ?from=roles/...
const chapterPhaseCtxMap: Record<string, { roleTitle: string; roleUrl: string; chapters: { slug: string; title: string; url: string }[] }> = {};
for (const role of getRoles().filter(r => !r.comingSoon && r.phases)) {
  const phases = resolveRolePhases(role);
  if (!phases) continue;
  phases.forEach((phase, pi) => {
    if (phase.isEmpty) return;
    const slugsInPhase = phase.sections.map(s => s.topics[0]?.chapterSlug).filter(Boolean);
    if (!slugsInPhase.includes(chapterSlug)) return;
    const key = `${role.slug}/${pi + 1}`;
    chapterPhaseCtxMap[key] = {
      roleTitle: role.title,
      roleUrl: role.url,
      chapters: phase.sections.map(s => ({
        slug: s.topics[0]?.chapterSlug ?? '',
        title: s.title,
        url: (s.topics[0]?.chapterUrl ?? '') + `?from=roles/${key}`,
      })),
    };
  });
}
const chapterPhaseCtxJson = JSON.stringify({ currentChapterSlug: chapterSlug, bgClass, textClass, map: chapterPhaseCtxMap });
---
<BaseLayout title={`${chapter.title} — ${back.label}`} description={chapter.description}>
  <!-- Top nav -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3">
    <div class="flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} title="Home" class="flex h-5 items-center text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a id="nav-back-link" href={back.href} class="flex items-center gap-2 text-sm text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h18M3 12l7-7M3 12l7 7"/>
        </svg>
        {back.label}
      </a>
    </div>

  </header>

  <div class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#444444_1px,transparent_1px),linear-gradient(to_bottom,#444444_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none chapter-radial-bg"></div>

  <main class="relative z-10 max-w-3xl mx-auto px-6 pt-24 pb-16 animate-slide-up">
    <!-- Chapter header -->
    <p class={`text-sm font-medium ${textClass} mb-2`}>Chapter {chapter.order}</p>
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">{chapter.title}</h1>
    <p class="text-lg text-gray-500 dark:text-neutral-400 mb-10">{chapter.description}</p>

    <!-- Topic list -->
    <ol class="space-y-3">
      {topics.map((topic, i) => (
        <li>
          <a
            href={topic.url}
            class={`group flex items-start gap-4 p-4 rounded-xl border ${borderClass} bg-white dark:bg-neutral-900 hover:bg-gray-50 dark:hover:bg-neutral-900/70 transition-all`}
          >
            <!-- Topic number -->
            <span class={`text-sm font-mono font-bold ${textClass} w-6 shrink-0 mt-0.5`}>{String(i + 1).padStart(2, '0')}</span>
            <div class="flex-1 min-w-0">
              <p class="text-gray-900 dark:text-white font-medium">{topic.title}</p>
              <p class="text-sm text-gray-500 dark:text-neutral-500 mt-0.5">{topic.description}</p>
            </div>
            <div class="flex items-center gap-3 shrink-0 mt-0.5">
              {topic.widget && (
                <span class="text-xs text-emerald-600 dark:text-emerald-500 bg-emerald-50 dark:bg-emerald-500/10 px-2 py-0.5 rounded-full">interactive</span>
              )}
              <span class="text-xs text-gray-400 dark:text-neutral-600">{topic.estimatedMinutes} min</span>
              <!-- Completion dot (filled by JS) -->
              <span
                class="topic-completion-dot w-2 h-2 rounded-full bg-gray-200 dark:bg-neutral-700 transition-colors"
                data-topic-id={`${chapter.slug}/${topic.slug}`}
              ></span>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <!-- Start chapter CTA -->
    <div class="mt-10 flex items-center gap-4">
      <a
        href={topics[0]?.url ?? import.meta.env.BASE_URL}
        class={`inline-flex items-center gap-2 ${bgClass} ${textClass} font-semibold px-5 py-2.5 rounded-xl border ${borderClass} hover:opacity-90 transition-opacity`}
      >
        Start chapter
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <a id="chapter-back-overview" href={back.href} class="text-sm text-gray-400 dark:text-neutral-500 hover:text-gray-600 dark:hover:text-neutral-300 transition-colors">Back to overview</a>
    </div>
  </main>
  </div>
  <script is:inline define:vars={{ chapterPhaseCtxJson }}>window.__chapterPhaseCtx = JSON.parse(chapterPhaseCtxJson);</script>
</BaseLayout>

<style define:vars={{ gradientLight: gradientColor.light, gradientDark: gradientColor.dark }}>
  .chapter-radial-bg {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, var(--gradientLight), transparent);
  }
  :global(.dark) .chapter-radial-bg {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, var(--gradientDark), transparent);
  }
</style>

<script>
  const STORAGE_KEY = 'platform-progress';
  function getProgress(): Record<string, boolean> {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
    catch { return {}; }
  }
  const progress = getProgress();
  document.querySelectorAll<HTMLSpanElement>('.topic-completion-dot').forEach((dot) => {
    const id = dot.dataset.topicId ?? '';
    if (progress[id]) {
      dot.classList.remove('bg-gray-200', 'dark:bg-neutral-700');
      dot.classList.add('bg-emerald-500');
    }
  });
</script>
