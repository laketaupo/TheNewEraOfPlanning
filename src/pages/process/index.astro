---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getChapters } from '../../lib/chapters';

const allProcessChapters = getChapters('process').filter(c => !c.hidden);
const foundationsChapterCount = allProcessChapters.filter(c => c.module === 'process-foundations').length;
const sopChapterCount    = allProcessChapters.filter(c => c.module === 'sop-process').length;
const soeChapterCount    = allProcessChapters.filter(c => c.module === 'soe-process').length;
const execChapterCount   = allProcessChapters.filter(c => c.module === 'execution-process').length;
const scenarioChapterCount = allProcessChapters.filter(c => c.module === 'scenario-planning').length;
---
<BaseLayout title="Process">
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-3 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} title="Home" class="flex items-center text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href="/" class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        The New Era of Planning
      </a>
    </div>
    <ThemeToggle />
  </header>

  <div class="relative min-h-screen overflow-hidden pt-12">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <div class="relative z-10 px-6 pt-14 pb-12 max-w-3xl mx-auto text-center animate-fade-in">
      <div class="inline-flex items-center gap-2 text-xs font-medium text-violet-600 dark:text-violet-400 bg-violet-50 dark:bg-violet-500/10 border border-violet-200 dark:border-violet-500/30 rounded-full px-3 py-1 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse"></span>
        Process
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4 leading-tight tracking-tight">
        Explore <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-500 to-purple-500">Process</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-lg mx-auto leading-relaxed">
        Master the planning operating model — from the monthly S&amp;OP cycle and weekly S&amp;OE through daily execution, underpinned by governance policies and the scenario tools that handle uncertainty.
      </p>
    </div>

    <div class="relative z-10 px-6 pb-20 max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <!-- Process Foundations -->
        <a href="/process/process-foundations" class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
          </div>
          <h2 class="track-title">Process Foundations</h2>
          <p class="track-desc">The operating model, planning policies, governance structure, and KPIs that apply across all planning processes.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {foundationsChapterCount} chapters available
          </span>
        </a>

        <!-- S&OP Process -->
        <a href="/process/sop-process" class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h2 class="track-title">S&amp;OP Process</h2>
          <p class="track-desc">Learn the monthly Sales &amp; Operations Planning cycle — aligning demand, supply, and finance into one agreed plan.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {sopChapterCount} chapters available
          </span>
        </a>

        <!-- S&OE Process -->
        <a href="/process/soe-process" class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <h2 class="track-title">S&amp;OE Process</h2>
          <p class="track-desc">Master the weekly Sales &amp; Operations Execution cycle — managing the gap between the plan and operational reality.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {soeChapterCount} chapters available
          </span>
        </a>

        <!-- Execution Process -->
        <a href="/process/execution-process" class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h2 class="track-title">Execution Process</h2>
          <p class="track-desc">Understand the daily execution layer — how confirmed plans become shipped orders, produced batches, and delivered commitments.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {execChapterCount} chapters available
          </span>
        </a>

        <!-- Scenario Planning -->
        <a href="/process/scenario-planning" class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3h6m-6 0v7l-4 9a1 1 0 001 1h12a1 1 0 001-1l-4-9V3"/>
            </svg>
          </div>
          <h2 class="track-title">Scenario Planning</h2>
          <p class="track-desc">Explore uncertainty and compare outcomes to make better planning decisions with Planning software.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {scenarioChapterCount} chapters available
          </span>
        </a>

      </div>
    </div>
  </div>

  <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-600">
    <p>Built with Astro · Content in Markdown · Maintained with Claude</p>
  </footer>
</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(139,92,246,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(139,92,246,0.15), transparent);
  }

  .track-card {
    @apply flex flex-col p-7 rounded-2xl text-white transition-all duration-200 hover:-translate-y-1 cursor-pointer no-underline;
  }
  .track-card:hover { filter: brightness(1.08); }

  .track-process {
    background: linear-gradient(135deg, #7c3aed, #8b5cf6);
    box-shadow: 0 8px 32px rgba(139,92,246,0.25);
  }

  .track-icon {
    @apply w-11 h-11 rounded-xl flex items-center justify-center mb-5;
    background: rgba(255,255,255,0.15);
  }
  .track-title {
    @apply text-xl font-bold text-white mb-2;
  }
  .track-desc {
    @apply text-sm leading-relaxed mb-5 flex-1;
    color: rgba(255,255,255,0.75);
  }
  .track-badge {
    @apply inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full self-start;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
  }
  .track-badge-live {
    background: rgba(255,255,255,0.2);
  }
  .live-dot {
    @apply w-1.5 h-1.5 rounded-full bg-white;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
