---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getChapters } from '../../lib/chapters';

const allProcessChapters = getChapters('process').filter(c => !c.hidden);
const foundationsChapterCount = allProcessChapters.filter(c => c.module === 'process-fundamentals').length;
const sopChapterCount    = allProcessChapters.filter(c => c.module === 'sop-process').length;
const soeChapterCount    = allProcessChapters.filter(c => c.module === 'soe-process').length;
const execChapterCount   = allProcessChapters.filter(c => c.module === 'execution-process').length;
const scenarioChapterCount = allProcessChapters.filter(c => c.module === 'scenario-planning').length;
---
<BaseLayout title="Process">
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-3">
    <div class="flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} title="Home" class="flex h-5 items-center text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        The New Era of Planning
      </a>
    </div>
    
  </header>

  <div class="relative min-h-screen overflow-hidden pt-12">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#444444_1px,transparent_1px),linear-gradient(to_bottom,#444444_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <div class="relative z-10 px-6 pt-14 pb-12 max-w-3xl mx-auto text-center animate-fade-in">
      <div class="inline-flex items-center gap-2 text-xs font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/30 rounded-full px-3 py-1 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
        Process
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4 leading-tight tracking-tight">
        Explore <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-indigo-500">Process</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-neutral-400 max-w-lg mx-auto leading-relaxed">
        Master the planning operating model — from the monthly S&amp;OP cycle and weekly S&amp;OE through daily execution, underpinned by governance policies and the scenario tools that handle uncertainty.
      </p>
    </div>

    <div class="relative z-10 px-6 pb-20 max-w-5xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

        <!-- Process Fundamentals -->
        <a href={`${import.meta.env.BASE_URL}process/process-fundamentals`} class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
          </div>
          <h2 class="track-title">Process Fundamentals</h2>
          <p class="track-desc">The operating model, planning policies, governance structure, and KPIs that apply across all planning processes.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {foundationsChapterCount} chapters available
          </span>
        </a>

        <!-- S&OP Process -->
        <a href={`${import.meta.env.BASE_URL}process/sop-process`} class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h2 class="track-title">S&amp;OP</h2>
          <p class="track-desc">Learn the monthly Sales &amp; Operations Planning cycle — aligning demand, supply, and finance into one agreed plan.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {sopChapterCount} chapters available
          </span>
        </a>

        <!-- S&OE Process -->
        <a href={`${import.meta.env.BASE_URL}process/soe-process`} class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <h2 class="track-title">S&amp;OE</h2>
          <p class="track-desc">Master the weekly Sales &amp; Operations Execution cycle — managing the gap between the plan and operational reality.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {soeChapterCount} chapters available
          </span>
        </a>

        <!-- Execution Process -->
        <a href={`${import.meta.env.BASE_URL}process/execution-process`} class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h2 class="track-title">Execution</h2>
          <p class="track-desc">Understand the daily execution layer — how confirmed plans become shipped orders, produced batches, and delivered commitments.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {execChapterCount} chapters available
          </span>
        </a>

        <!-- Scenario Planning -->
        <a href={`${import.meta.env.BASE_URL}process/scenario-planning`} class="group track-card track-process">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3h6m-6 0v7l-4 9a1 1 0 001 1h12a1 1 0 001-1l-4-9V3"/>
            </svg>
          </div>
          <h2 class="track-title">Scenario Planning</h2>
          <p class="track-desc">Explore uncertainty and compare outcomes to make better planning decisions with Planning software.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {scenarioChapterCount} chapters available
          </span>
        </a>

      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.15), transparent);
  }

  .track-card {
    @apply flex flex-col rounded-2xl transition-all duration-200 hover:-translate-y-1 cursor-pointer no-underline;
    padding: 2.5rem;
    border-top-width: 4px;
    border-top-style: solid;
  }

  /* ── Light mode ─────────────────────────────────── */
  .track-process {
    background: #eff6ff;
    border: 1.5px solid #bfdbfe;
    border-top: 4px solid #93c5fd;
  }
  .track-card:hover { box-shadow: 0 6px 24px rgba(59,130,246,0.12); }

  /* ── Dark mode ──────────────────────────────────── */
  :global(.dark) .track-process {
    background: #2c2c2c;
    border-color: rgba(59,130,246,0.18);
    border-top-color: rgba(147,197,253,0.5);
  }
  :global(.dark) .track-card:hover {
    background: #363636;
    box-shadow: 0 6px 28px rgba(59,130,246,0.12);
  }

  /* ── Icon ───────────────────────────────────────── */
  .track-icon {
    @apply w-14 h-14 rounded-xl flex items-center justify-center mb-5;
    background: #dbeafe;
    color: #1d4ed8;
  }
  :global(.dark) .track-icon {
    background: rgba(59,130,246,0.12);
    color: #93c5fd;
  }

  /* ── Title ──────────────────────────────────────── */
  .track-title { @apply text-xl font-bold mb-2; color: #111827; }
  :global(.dark) .track-title { color: #f3f4f6; }

  /* ── Description ────────────────────────────────── */
  .track-desc { @apply text-sm leading-relaxed mb-5 flex-1; color: #6b7280; }
  :global(.dark) .track-desc { color: rgba(243,244,246,0.45); }

  /* ── Badge ──────────────────────────────────────── */
  .track-badge {
    @apply inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full self-start;
    background: #dbeafe;
    color: #1e40af;
  }
  :global(.dark) .track-badge {
    background: rgba(59,130,246,0.12);
    color: #93c5fd;
  }

  .live-dot {
    @apply w-1.5 h-1.5 rounded-full;
    background: currentColor;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
