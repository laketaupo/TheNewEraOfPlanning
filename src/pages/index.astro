---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { getRoles, resolveRoleSections, getRoleStats } from '../lib/roles';

const techModuleCount = 5;
const peopleModuleCount = 2;
const processModuleCount = 4;
const dataModuleCount = 1;

const roles = getRoles().map((role) => {
  const stats = role.comingSoon ? null : getRoleStats(resolveRoleSections(role));
  const halfHours = stats ? Math.round(stats.totalMinutes / 30) * 0.5 : 0;
  return { ...role, stats, hoursLabel: stats ? `~${halfHours} hrs` : '' };
});

const DEPARTMENT_ORDER = [
  'Supply Chain',
  'Finance / Business Control',
  'Product Management',
  'Operations',
  'Sales',
  'Production',
  'Subsidiary',
];

const rolesByDepartment = DEPARTMENT_ORDER.map((dept) => ({
  name: dept,
  roles: roles.filter((r) => r.department === dept),
})).filter((g) => g.roles.length > 0);

const roleColorTextMap: Record<string, string> = {
  indigo: 'text-indigo-600 dark:text-indigo-400',
  violet: 'text-violet-600 dark:text-violet-400',
  sky:    'text-sky-600 dark:text-sky-400',
  emerald:'text-emerald-600 dark:text-emerald-400',
  amber:  'text-amber-600 dark:text-amber-400',
  teal:   'text-teal-600 dark:text-teal-400',
};
const roleBadgeBgMap: Record<string, string> = {
  indigo: 'bg-indigo-50 dark:bg-indigo-500/10',
  violet: 'bg-violet-50 dark:bg-violet-500/10',
  sky:    'bg-sky-50 dark:bg-sky-500/10',
  emerald:'bg-emerald-50 dark:bg-emerald-500/10',
  amber:  'bg-amber-50 dark:bg-amber-500/10',
  teal:   'bg-teal-50 dark:bg-teal-500/10',
};
const roleColorBgMap: Record<string, string> = {
  indigo: 'bg-indigo-50 dark:bg-indigo-500/10 border-indigo-200 dark:border-indigo-500/30 hover:border-indigo-400 dark:hover:border-indigo-400',
  violet: 'bg-violet-50 dark:bg-violet-500/10 border-violet-200 dark:border-violet-500/30 hover:border-violet-400 dark:hover:border-violet-400',
  sky:    'bg-sky-50 dark:bg-sky-500/10 border-sky-200 dark:border-sky-500/30 hover:border-sky-400 dark:hover:border-sky-400',
  emerald:'bg-emerald-50 dark:bg-emerald-500/10 border-emerald-200 dark:border-emerald-500/30 hover:border-emerald-400 dark:hover:border-emerald-400',
  amber:  'bg-amber-50 dark:bg-amber-500/10 border-amber-200 dark:border-amber-500/30 hover:border-amber-400 dark:hover:border-amber-400',
  teal:   'bg-teal-50 dark:bg-teal-500/10 border-teal-200 dark:border-teal-500/30 hover:border-teal-400 dark:hover:border-teal-400',
};

const roleIconMap: Record<string, string> = {
  truck: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>`,
  beaker: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3h6m-6 0v7l-4 9a1 1 0 001 1h12a1 1 0 001-1l-4-9V3"/></svg>`,
  'trending-up': `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`,
  currency: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  briefcase: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  chart: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
};
---
<BaseLayout title="The New Era of Planning">
  <!-- Floating theme toggle -->
  <div class="fixed top-3 right-4 z-50">
    <ThemeToggle />
  </div>

  <!-- Page wrapper -->
  <div class="relative min-h-screen overflow-hidden">
    <!-- Background grid -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <!-- Radial gradient -->
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <!-- Header -->
    <div class="relative z-10 px-6 pt-20 pb-12 max-w-3xl mx-auto text-center animate-fade-in">
      <div class="inline-flex items-center gap-2 text-xs font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/30 rounded-full px-3 py-1 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
        Planning software
      </div>

      <h1 class="text-5xl sm:text-6xl font-bold text-gray-900 dark:text-white mb-6 leading-tight tracking-tight">
        The New Era of<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-violet-500 to-pink-500">Planning</span>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-xl mx-auto leading-relaxed">
        Explore the people, processes, technology, and data that power modern supply chain planning.
      </p>
    </div>

    <!-- 2×2 Pillar grid -->
    <div class="relative z-10 px-6 pb-20 max-w-3xl mx-auto">
      <div class="grid grid-cols-2 gap-5">

        <!-- People -->
        <a href="/people" class="group pillar-card pillar-people">
          <div class="pillar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a4 4 0 00-5-3.87M9 20H4v-2a4 4 0 015-3.87m6-4.13a4 4 0 10-8 0 4 4 0 008 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h2 class="pillar-title">People</h2>
          <p class="pillar-desc">Roles, mindsets, and collaboration patterns that drive planning success.</p>
          <span class="pillar-badge pillar-badge-live">
            <span class="live-dot"></span>
            {peopleModuleCount} modules available
          </span>
        </a>

        <!-- Process -->
        <a href="/process" class="group pillar-card pillar-process">
          <div class="pillar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3" stroke-width="1.5"/>
            </svg>
          </div>
          <h2 class="pillar-title">Process</h2>
          <p class="pillar-desc">How planning workflows are structured, governed, and continuously improved.</p>
          <span class="pillar-badge pillar-badge-live">
            <span class="live-dot"></span>
            {processModuleCount} modules available
          </span>
        </a>

        <!-- Technology -->
        <a href="/technology" class="group pillar-card pillar-technology">
          <div class="pillar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0v10l-8 4M4 7v10l8 4"/>
            </svg>
          </div>
          <h2 class="pillar-title">Technology</h2>
          <p class="pillar-desc">From building blocks to live scenario simulation — a guided tour of the Planning software.</p>
          <span class="pillar-badge pillar-badge-live">
            <span class="live-dot"></span>
            {techModuleCount} modules available
          </span>
        </a>

        <!-- Data -->
        <a href="/data" class="group pillar-card pillar-data">
          <div class="pillar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h2 class="pillar-title">Data</h2>
          <p class="pillar-desc">Data models, signals, and structures that feed intelligent planning decisions.</p>
          <span class="pillar-badge pillar-badge-live">
            <span class="live-dot"></span>
            {dataModuleCount} modules available
          </span>
        </a>

      </div>
    </div>

    <!-- Learn by role -->
    <div class="relative z-10 px-6 pb-20 max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Learn by role</h2>
        <p class="text-gray-500 dark:text-gray-400">A curated learning path with exactly what you need for your position.</p>
      </div>

      <div class="space-y-10">
        {rolesByDepartment.map(({ name, roles: deptRoles }) => (
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-4">{name}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {deptRoles.map((role) => {
                const textClass = roleColorTextMap[role.color] ?? roleColorTextMap.indigo;
                const bgClass = roleColorBgMap[role.color] ?? roleColorBgMap.indigo;
                const icon = roleIconMap[role.icon] ?? roleIconMap.beaker;
                const cardInner = (
                  <>
                    <div class={`${textClass} mb-3`} set:html={icon} />
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1 leading-snug">{role.title}</h3>
                    <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed mb-4 flex-1">{role.description}</p>
                    {role.stats ? (
                      <span class={`inline-flex items-center gap-1.5 text-[11px] font-semibold px-2.5 py-1 rounded-full self-start ${roleBadgeBgMap[role.color] ?? roleBadgeBgMap.indigo} ${textClass}`}>
                        <span class="role-live-dot"></span>
                        {role.stats.topicCount} topics · {role.hoursLabel}
                      </span>
                    ) : (
                      <span class="role-badge-soon">Coming soon</span>
                    )}
                  </>
                );
                return role.stats ? (
                  <a href={role.url} class={`group flex flex-col p-5 rounded-2xl border ${bgClass} bg-white dark:bg-transparent transition-all duration-200 hover:-translate-y-1 hover:shadow-xl dark:hover:shadow-2xl no-underline`}>
                    {cardInner}
                  </a>
                ) : (
                  <div class="flex flex-col p-5 rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-transparent opacity-60">
                    {cardInner}
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-600">
    <p>Built with Astro · Content in Markdown · Maintained with Claude</p>
  </footer>
</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99,102,241,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99,102,241,0.15), transparent);
  }

  .pillar-card {
    @apply flex flex-col p-7 rounded-2xl text-white transition-all duration-200 hover:-translate-y-1 cursor-pointer no-underline;
  }

  .pillar-people    { background: linear-gradient(135deg, #4f46e5, #6366f1); box-shadow: 0 8px 32px rgba(99,102,241,0.25); }
  .pillar-process   { background: linear-gradient(135deg, #7c3aed, #8b5cf6); box-shadow: 0 8px 32px rgba(139,92,246,0.25); }
  .pillar-technology{ background: linear-gradient(135deg, #0284c7, #0ea5e9); box-shadow: 0 8px 32px rgba(14,165,233,0.25); }
  .pillar-data      { background: linear-gradient(135deg, #059669, #10b981); box-shadow: 0 8px 32px rgba(16,185,129,0.25); }

  .pillar-card:hover { filter: brightness(1.08); }

  .pillar-icon {
    @apply w-11 h-11 rounded-xl flex items-center justify-center mb-5;
    background: rgba(255,255,255,0.15);
  }

  .pillar-title {
    @apply text-xl font-bold text-white mb-2;
  }

  .pillar-desc {
    @apply text-sm leading-relaxed mb-5 flex-1;
    color: rgba(255,255,255,0.75);
  }

  .pillar-badge {
    @apply inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full self-start;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
  }

  .pillar-badge-live {
    background: rgba(255,255,255,0.2);
  }

  .live-dot {
    @apply w-1.5 h-1.5 rounded-full bg-white;
    animation: pulse 2s infinite;
  }

  .role-live-dot {
    @apply w-1.5 h-1.5 rounded-full bg-current;
    animation: pulse 2s infinite;
  }

  .role-badge-soon {
    @apply inline-flex items-center text-[11px] font-semibold px-2.5 py-1 rounded-full self-start bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
