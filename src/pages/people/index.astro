---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getChapters } from '../../lib/chapters';

const allPeopleChapters = getChapters('people').filter(c => !c.hidden);
const orgRolesCount = allPeopleChapters.filter(c => c.module === 'organisation-and-roles').length;
---
<BaseLayout title="People">
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-3 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} title="Home" class="flex h-5 items-center text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href="/" class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        The New Era of Planning
      </a>
    </div>
    <ThemeToggle />
  </header>

  <div class="relative min-h-screen overflow-hidden pt-12">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <div class="relative z-10 px-6 pt-14 pb-12 max-w-3xl mx-auto text-center animate-fade-in">
      <div class="inline-flex items-center gap-2 text-xs font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 rounded-full px-3 py-1 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
        People
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4 leading-tight tracking-tight">
        Explore <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-rose-500">People</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-lg mx-auto leading-relaxed">
        Understand the roles, responsibilities, and governance that make supply chain planning work — and how to land a lasting transformation.
      </p>
    </div>

    <div class="relative z-10 px-6 pb-20 max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <!-- Organisation & Roles -->
        <a href="/people/organisation-and-roles" class="group track-card track-org-roles">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a4 4 0 00-5-3.87M9 20H4v-2a4 4 0 015-3.87m6-4.13a4 4 0 10-8 0 4 4 0 008 0zm6 0a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h2 class="track-title">Organisation &amp; Roles</h2>
          <p class="track-desc">The team behind supply chain planning — who fills each role, how they're structured, and who's accountable for what.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {orgRolesCount} chapters available
          </span>
        </a>

      </div>
    </div>
  </div>

  <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-600">
    <p>Built with Astro · Content in Markdown · Maintained with Claude</p>
  </footer>
</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(239,68,68,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(239,68,68,0.15), transparent);
  }

  .track-card {
    @apply flex flex-col rounded-2xl transition-all duration-200 hover:-translate-y-1 cursor-pointer no-underline;
    padding: 1.75rem;
    padding-top: 1.5rem;
    border-top-width: 4px;
    border-top-style: solid;
  }

  /* ── Light mode ─────────────────────────────────── */
  .track-org-roles {
    background: #fff5f5;
    border: 1.5px solid #fecaca;
    border-top: 4px solid #fca5a5;
  }
  .track-card:hover { box-shadow: 0 6px 24px rgba(239,68,68,0.13); }

  /* ── Dark mode ──────────────────────────────────── */
  :global(.dark) .track-org-roles {
    background: rgba(239,68,68,0.06);
    border-color: rgba(239,68,68,0.18);
    border-top-color: rgba(252,165,165,0.5);
  }
  :global(.dark) .track-card:hover {
    background: rgba(239,68,68,0.09);
    box-shadow: 0 6px 28px rgba(239,68,68,0.12);
  }

  /* ── Icon ───────────────────────────────────────── */
  .track-icon {
    @apply w-11 h-11 rounded-xl flex items-center justify-center mb-5;
    background: #fee2e2;
    color: #b91c1c;
  }
  :global(.dark) .track-icon {
    background: rgba(239,68,68,0.12);
    color: #fca5a5;
  }

  /* ── Title ──────────────────────────────────────── */
  .track-title { @apply text-xl font-bold mb-2; color: #111827; }
  :global(.dark) .track-title { color: #f3f4f6; }

  /* ── Description ────────────────────────────────── */
  .track-desc { @apply text-sm leading-relaxed mb-5 flex-1; color: #6b7280; }
  :global(.dark) .track-desc { color: rgba(243,244,246,0.45); }

  /* ── Badge ──────────────────────────────────────── */
  .track-badge {
    @apply inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full self-start;
    background: #fee2e2;
    color: #991b1b;
  }
  :global(.dark) .track-badge {
    background: rgba(239,68,68,0.12);
    color: #fca5a5;
  }

  .live-dot {
    @apply w-1.5 h-1.5 rounded-full;
    background: currentColor;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
