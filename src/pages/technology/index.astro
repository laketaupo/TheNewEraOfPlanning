---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getChapters } from '../../lib/chapters';

const chapters = getChapters('technology');
const chapterCount = chapters.filter(c => !c.hidden && c.module === 'planning-software').length;
---
<BaseLayout title="Technology">
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-3">
    <div class="flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} title="Home" class="flex h-5 items-center text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href="/" class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-neutral-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        The New Era of Planning
      </a>
    </div>
    
  </header>

  <div class="relative min-h-screen overflow-hidden pt-12">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#444444_1px,transparent_1px),linear-gradient(to_bottom,#444444_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <div class="relative z-10 px-6 pt-14 pb-12 max-w-3xl mx-auto text-center animate-fade-in">
      <div class="inline-flex items-center gap-2 text-xs font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/30 rounded-full px-3 py-1 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
        Technology
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4 leading-tight tracking-tight">
        Explore <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-indigo-500">Technology</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-neutral-400 max-w-lg mx-auto leading-relaxed">
        Understand the systems that power modern supply chain planning — the Planning software model, ERP data flows, master data management, field systems, and how they all connect.
      </p>
    </div>

    <div class="relative z-10 px-6 pb-20 max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <!-- Planning Software -->
        <a href="/technology/planning-software" class="group track-card track-how-platform">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0v10l-8 4M4 7v10l8 4"/>
            </svg>
          </div>
          <h2 class="track-title">Planning Software</h2>
          <p class="track-desc">From building blocks to live scenario simulation — a guided tour of the Planning software.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {chapterCount} chapters available
          </span>
        </a>

        <!-- ERP -->
        <a href="/technology/erp" class="group track-card track-bc">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h2 class="track-title">ERP</h2>
          <p class="track-desc">The system that executes the plan — how to navigate it and how it connects to Planning software.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            ERP guide
          </span>
        </a>

        <!-- Architecture & Integration -->
        <a href="/technology/architecture" class="group track-card track-arch">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
            </svg>
          </div>
          <h2 class="track-title">Architecture &amp; Integration</h2>
          <p class="track-desc">Interfaces, batch runs, and data flows — how ERP, Planning software, FMS, and MDM system stay in sync.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            Integration guide
          </span>
        </a>

        <!-- MDM Tool -->
        <a href="/technology/mdm" class="group track-card track-mdm">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 1.1.9 2 2 2h12a2 2 0 002-2V7M4 7c0-1.1.9-2 2-2h12a2 2 0 012 2M4 7h16M8 11h8M8 15h5"/>
            </svg>
          </div>
          <h2 class="track-title">MDM Tool</h2>
          <p class="track-desc">The master data hub — product records, hierarchies, and planning parameters that all other systems depend on.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            Master data guide
          </span>
        </a>

        <!-- FMS Tool -->
        <a href="/technology/fms" class="group track-card track-fms">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
            </svg>
          </div>
          <h2 class="track-title">FMS Tool</h2>
          <p class="track-desc">Field management tracking grower contracts, crop development, and harvest signals for supply-side planning.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            Field management guide
          </span>
        </a>

        <!-- Reporting -->
        <a href="/technology/reporting" class="group track-card track-reporting">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h2 class="track-title">Reporting</h2>
          <p class="track-desc">Power BI dashboards and KPI reports — connecting planning outputs to the insights that drive decisions.</p>
          <span class="track-badge">
            Coming soon
          </span>
        </a>

      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.15), transparent);
  }

  .track-card {
    @apply flex flex-col rounded-2xl transition-all duration-200 hover:-translate-y-1 cursor-pointer no-underline;
    padding: 1.75rem;
    padding-top: 1.5rem;
    border-top-width: 4px;
    border-top-style: solid;
  }

  /* ── Light mode (all technology tracks = blue) ── */
  .track-how-platform,
  .track-bc,
  .track-arch,
  .track-mdm,
  .track-fms,
  .track-reporting {
    background: #eff6ff;
    border: 1.5px solid #bfdbfe;
    border-top: 4px solid #93c5fd;
  }
  .track-card:hover { box-shadow: 0 6px 24px rgba(59,130,246,0.12); }

  /* ── Dark mode ──────────────────────────────────── */
  :global(.dark) .track-how-platform,
  :global(.dark) .track-bc,
  :global(.dark) .track-arch,
  :global(.dark) .track-mdm,
  :global(.dark) .track-fms,
  :global(.dark) .track-reporting {
    background: #2c2c2c;
    border-color: rgba(59,130,246,0.18);
    border-top-color: rgba(147,197,253,0.5);
  }
  :global(.dark) .track-card:hover {
    background: #363636;
    box-shadow: 0 6px 28px rgba(59,130,246,0.12);
  }

  /* ── Icon ───────────────────────────────────────── */
  .track-icon {
    @apply w-11 h-11 rounded-xl flex items-center justify-center mb-5;
    background: #dbeafe;
    color: #1d4ed8;
  }
  :global(.dark) .track-icon {
    background: rgba(59,130,246,0.12);
    color: #93c5fd;
  }

  /* ── Title ──────────────────────────────────────── */
  .track-title { @apply text-xl font-bold mb-2; color: #111827; }
  :global(.dark) .track-title { color: #f3f4f6; }

  /* ── Description ────────────────────────────────── */
  .track-desc { @apply text-sm leading-relaxed mb-5 flex-1; color: #6b7280; }
  :global(.dark) .track-desc { color: rgba(243,244,246,0.45); }

  /* ── Badge ──────────────────────────────────────── */
  .track-badge {
    @apply inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full self-start;
    background: #dbeafe;
    color: #1e40af;
  }
  :global(.dark) .track-badge {
    background: rgba(59,130,246,0.12);
    color: #93c5fd;
  }
  .track-badge:not(.track-badge-live) {
    background: #f3f4f6;
    color: #6b7280;
  }
  :global(.dark) .track-badge:not(.track-badge-live) {
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.4);
  }

  .live-dot {
    @apply w-1.5 h-1.5 rounded-full;
    background: currentColor;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
