---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getChapters } from '../../lib/chapters';

const chapters = getChapters('technology');
const chapterCount = chapters.filter(c => !c.hidden).length;
---
<BaseLayout title="Technology">
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-3 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-3">
      <a href={import.meta.env.BASE_URL} title="Home" class="flex items-center text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <a href="/" class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        The New Era of Planning
      </a>
    </div>
    <ThemeToggle />
  </header>

  <div class="relative min-h-screen overflow-hidden pt-12">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:64px_64px] opacity-60 dark:opacity-40 pointer-events-none"></div>
    <div class="absolute inset-0 bg-radial-gradient pointer-events-none"></div>

    <div class="relative z-10 px-6 pt-14 pb-12 max-w-3xl mx-auto text-center animate-fade-in">
      <div class="inline-flex items-center gap-2 text-xs font-medium text-sky-600 dark:text-sky-400 bg-sky-50 dark:bg-sky-500/10 border border-sky-200 dark:border-sky-500/30 rounded-full px-3 py-1 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-sky-500 animate-pulse"></span>
        Technology
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4 leading-tight tracking-tight">
        Explore <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-indigo-500">Technology</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-lg mx-auto leading-relaxed">
        Understand the Planning software from two angles — how it works under the hood, and how to configure it for your business.
      </p>
    </div>

    <div class="relative z-10 px-6 pb-20 max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <!-- How Planning Software Works -->
        <a href="/technology/how-planning-software-works" class="group track-card track-how-platform">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0v10l-8 4M4 7v10l8 4"/>
            </svg>
          </div>
          <h2 class="track-title">How Planning Software Works</h2>
          <p class="track-desc">From building blocks to live scenario simulation — a guided tour of the Planning software.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            {chapterCount} chapters available
          </span>
        </a>

        <!-- Configuration Manual -->
        <a href="/technology/configuration" class="group track-card track-config">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h2 class="track-title">Configuration Manual</h2>
          <p class="track-desc">Step-by-step screenshots and explanations for configuring Planning software for your business.</p>
          <span class="track-badge">Business configuration guide</span>
        </a>

        <!-- ERP -->
        <a href="/technology/erp" class="group track-card track-bc">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h2 class="track-title">ERP</h2>
          <p class="track-desc">The system that executes the plan — how to navigate it and how it connects to Planning software.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            ERP guide
          </span>
        </a>

        <!-- Architecture & Integration -->
        <a href="/technology/architecture" class="group track-card track-arch">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
            </svg>
          </div>
          <h2 class="track-title">Architecture &amp; Integration</h2>
          <p class="track-desc">Interfaces, batch runs, and data flows — how ERP, Planning software, FMS, and MDM system stay in sync.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            Integration guide
          </span>
        </a>

        <!-- System Ecosystem -->
        <a href="/technology/ecosystem" class="group track-card track-eco">
          <div class="track-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
            </svg>
          </div>
          <h2 class="track-title">System Ecosystem</h2>
          <p class="track-desc">MDM system and FMS — the supporting systems that feed master data and field signals into planning.</p>
          <span class="track-badge track-badge-live">
            <span class="live-dot"></span>
            Supporting systems
          </span>
        </a>

      </div>
    </div>
  </div>

  <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-600">
    <p>Built with Astro · Content in Markdown · Maintained with Claude</p>
  </footer>
</BaseLayout>

<style>
  .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(14,165,233,0.08), transparent);
  }
  :global(.dark) .bg-radial-gradient {
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(14,165,233,0.15), transparent);
  }

  .track-card {
    @apply flex flex-col p-7 rounded-2xl text-white transition-all duration-200 hover:-translate-y-1 cursor-pointer no-underline;
  }
  .track-card:hover { filter: brightness(1.08); }

  .track-how-platform {
    background: linear-gradient(135deg, #0284c7, #0ea5e9);
    box-shadow: 0 8px 32px rgba(14,165,233,0.25);
  }
  .track-config {
    background: linear-gradient(135deg, #4338ca, #6366f1);
    box-shadow: 0 8px 32px rgba(99,102,241,0.25);
  }
  .track-bc {
    background: linear-gradient(135deg, #0369a1, #0284c7);
    box-shadow: 0 8px 32px rgba(2,132,199,0.25);
  }
  .track-arch {
    background: linear-gradient(135deg, #3730a3, #4f46e5);
    box-shadow: 0 8px 32px rgba(79,70,229,0.25);
  }
  .track-eco {
    background: linear-gradient(135deg, #047857, #10b981);
    box-shadow: 0 8px 32px rgba(16,185,129,0.25);
  }

  .track-icon {
    @apply w-11 h-11 rounded-xl flex items-center justify-center mb-5;
    background: rgba(255,255,255,0.15);
  }
  .track-title {
    @apply text-xl font-bold text-white mb-2;
  }
  .track-desc {
    @apply text-sm leading-relaxed mb-5 flex-1;
    color: rgba(255,255,255,0.75);
  }
  .track-badge {
    @apply inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full self-start;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
  }
  .track-badge-live {
    background: rgba(255,255,255,0.2);
  }
  .live-dot {
    @apply w-1.5 h-1.5 rounded-full bg-white;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
